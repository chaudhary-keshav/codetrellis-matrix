{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codetrellis.dev/schemas/practice.schema.json",
  "title": "BPL Practice Schema",
  "description": "JSON Schema for CodeTrellis Best Practices Library YAML files",
  "type": "object",
  "required": ["practices"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "framework": {
      "type": "string",
      "description": "Primary framework this file targets"
    },
    "description": {
      "type": "string",
      "description": "Description of the practice file"
    },
    "practices": {
      "type": "array",
      "description": "Array of best practices",
      "items": {
        "$ref": "#/definitions/Practice"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "Practice": {
      "type": "object",
      "required": ["id", "title", "category", "level", "priority", "content"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier with language prefix (PY*, TS*, NG*, FAST*, DP*, SOLID*)",
          "pattern": "^(PY|PYE|TS|NG|FAST|FLASK|DJANGO|NEST|REACT|DB|DEVOPS|DP|SOLID|GO|RS|JAVA)[A-Z]*\\d{3}$"
        },
        "title": {
          "type": "string",
          "description": "Short descriptive title",
          "minLength": 5,
          "maxLength": 100
        },
        "category": {
          "type": "string",
          "description": "Practice category",
          "enum": [
            "type_safety",
            "code_style",
            "patterns",
            "performance",
            "error_handling",
            "testing",
            "fastapi",
            "architecture",
            "security",
            "maintainability",
            "state_management",
            "configuration",
            "documentation",
            "async_patterns",
            "routing",
            "forms",
            "debugging",
            "solid_principles",
            "design_patterns",
            "concurrency",
            "best_practices",
            "lifecycle",
            "networking",
            "api_design",
            "naming",
            "typing",
            "clean_code",
            "angular_components",
            "angular_services",
            "angular_signals",
            "fastapi_endpoints",
            "creational",
            "structural",
            "behavioral",
            "solid",
            "database",
            "validation",
            "monitoring",
            "reliability",
            "accessibility",
            "user_experience",
            "automation",
            "containers",
            "deployment",
            "infrastructure"
          ]
        },
        "level": {
          "type": "string",
          "description": "Expertise level required",
          "enum": ["beginner", "intermediate", "advanced", "expert"]
        },
        "priority": {
          "type": "string",
          "description": "Importance/priority level",
          "enum": ["critical", "high", "medium", "low", "optional"]
        },
        "complexity_score": {
          "type": "integer",
          "description": "Implementation complexity (1-3: simple, 4-6: moderate, 7-10: complex)",
          "minimum": 1,
          "maximum": 10
        },
        "anti_pattern_id": {
          "type": "string",
          "description": "ID of related anti-pattern practice for cross-referencing",
          "pattern": "^(PY|PYE|TS|NG|FAST|FLASK|DJANGO|NEST|REACT|DB|DEVOPS|DP|SOLID|GO|RS|JAVA)[A-Z]*\\d{3}$"
        },
        "python_version": {
          "$ref": "#/definitions/VersionConstraint",
          "description": "Python version constraints"
        },
        "applicability": {
          "$ref": "#/definitions/ApplicabilityRule",
          "description": "Rules for when this practice applies"
        },
        "content": {
          "$ref": "#/definitions/PracticeContent",
          "description": "The actual practice content"
        },
        "solid_principles": {
          "type": "array",
          "description": "Related SOLID principles",
          "items": {
            "type": "string",
            "enum": ["SRP", "OCP", "LSP", "ISP", "DIP"]
          }
        },
        "design_patterns": {
          "type": "array",
          "description": "Related design patterns",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "VersionConstraint": {
      "type": "object",
      "properties": {
        "min_version": {
          "type": "string",
          "description": "Minimum version (inclusive)",
          "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
        },
        "max_version": {
          "type": "string",
          "description": "Maximum version (inclusive)",
          "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
        },
        "excluded_versions": {
          "type": "array",
          "description": "Specific versions to exclude",
          "items": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
          }
        }
      }
    },
    "ApplicabilityRule": {
      "type": "object",
      "properties": {
        "frameworks": {
          "type": "array",
          "description": "Frameworks that must be detected",
          "items": {
            "type": "string"
          }
        },
        "patterns": {
          "type": "array",
          "description": "Architecture patterns that must be present",
          "items": {
            "type": "string"
          }
        },
        "file_patterns": {
          "type": "array",
          "description": "Glob patterns for applicable files",
          "items": {
            "type": "string"
          }
        },
        "has_dependencies": {
          "type": "array",
          "description": "Required package dependencies",
          "items": {
            "type": "string"
          }
        },
        "project_types": {
          "type": "array",
          "description": "Applicable project types",
          "items": {
            "type": "string"
          }
        },
        "excluded_patterns": {
          "type": "array",
          "description": "Patterns that exclude this rule",
          "items": {
            "type": "string"
          }
        },
        "min_python": {
          "type": "string",
          "description": "Minimum Python version required (e.g., '3.10')",
          "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
        },
        "contexts": {
          "type": "array",
          "description": "Usage contexts where this practice is most relevant",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PracticeContent": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Full description of the practice",
          "minLength": 20
        },
        "rationale": {
          "type": "string",
          "description": "Why this practice is important"
        },
        "good_examples": {
          "type": "array",
          "description": "Code examples showing correct usage",
          "items": {
            "type": "string"
          }
        },
        "bad_examples": {
          "type": "array",
          "description": "Anti-pattern examples",
          "items": {
            "type": "string"
          }
        },
        "references": {
          "type": "array",
          "description": "External reference links",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "related_practices": {
          "type": "array",
          "description": "IDs of related practices",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "description": "Additional searchable tags",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
