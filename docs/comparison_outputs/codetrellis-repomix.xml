#!/usr/bin/env python3
"""
Manual test script to validate Python extractors on sparse-reasoning-ai project.
Run from tools/codetrellis directory with: python test_python_on_sparse_ai.py
"""

import sys
import os
from pathlib import Path

# Add codetrellis to path
sys.path.insert(0, str(Path(__file__).parent))

from codetrellis.python_parser_enhanced import EnhancedPythonParser

def test_file(file_path: str):
    """Test a single Python file."""
    print(f"\n{'='*60}")
    print(f"Testing: {file_path}")
    print('='*60)

    with open(file_path, 'r') as f:
        content = f.read()

    parser = EnhancedPythonParser()
    result = parser.parse(content, file_path)

    print(f"\nDetected Frameworks: {result.detected_frameworks}")

    # Show what was found
    if result.dataclasses:
        print(f"\n[DATACLASSES] Found {len(result.dataclasses)}:")
        for dc in result.dataclasses[:3]:
            print(f"  - {dc.name}")

    if result.pydantic_models:
        print(f"\n[PYDANTIC] Found {len(result.pydantic_models)}:")
        for m in result.pydantic_models[:3]:
            print(f"  - {m.name}")

    if result.functions:
        print(f"\n[FUNCTIONS] Found {len(result.functions)}:")
        for f in result.functions[:5]:
            print(f"  - {f.name}()")

    if result.classes:
        print(f"\n[CLASSES] Found {len(result.classes)}:")
        for c in result.classes[:5]:
            print(f"  - {c.name}")

    # ML/AI
    if result.pytorch:
        modules = result.pytorch.get('modules', [])
        if modules:
            print(f"\n[PYTORCH] Found {len(modules)} nn.Module(s):")
            for m in modules[:3]:
                print(f"  - {m.name}")

        training = result.pytorch.get('training_loops', [])
        if training:
            print(f"  Training loops: {len(training)}")

    if result.huggingface:
        models = result.huggingface.get('models', [])
        if models:
            print(f"\n[HUGGINGFACE] Found {len(models)} model(s):")
            for m in models[:3]:
                print(f"  - {m.name}")

    if result.langchain:
        chains = result.langchain.get('chains', [])
        if chains:
            print(f"\n[LANGCHAIN] Found {len(chains)} chain(s)")

    # Data
    if result.pandas:
        dfs = result.pandas.get('dataframes', [])
        if dfs:
            print(f"\n[PANDAS] Found {len(dfs)} DataFrame(s):")
            for df in dfs[:3]:
                print(f"  - {df.name} from {df.source}")

    # Config
    if result.config:
        hydra = result.config.get('hydra', [])
        if hydra:
            print(f"\n[HYDRA] Found {len(hydra)} config(s)")

        env_vars = result.config.get('env_vars', [])
        if env_vars:
            print(f"\n[ENV_VARS] Found {len(env_vars)}:")
            for v in env_vars[:5]:
                print(f"  - {v.name}")

    # MLflow
    if result.mlflow:
        experiments = result.mlflow.get('experiments', [])
        if experiments:
            print(f"\n[MLFLOW] Found {len(experiments)} experiment(s)")

        models = result.mlflow.get('models', [])
        if models:
            print(f"  Models logged: {len(models)}")

    # Generate CodeTrellis output
    codetrellis_output = parser.to_codetrellis_format(result)

    print(f"\n--- CodeTrellis OUTPUT (first 1500 chars) ---")
    print(codetrellis_output[:1500])
    if len(codetrellis_output) > 1500:
        print(f"\n... ({len(codetrellis_output)} total chars)")

    return result


def main():
    sparse_ai_path = Path(__file__).parent.parent.parent / "ai" / "sparse-reasoning-ai" / "src"

    if not sparse_ai_path.exists():
        print(f"ERROR: sparse-reasoning-ai not found at {sparse_ai_path}")
        return

    print(f"Sparse AI path: {sparse_ai_path}")

    # Find some interesting Python files to test
    test_files = []

    # Look for files with ML patterns
    for pattern in ["**/model*.py", "**/train*.py", "**/config*.py", "**/pipeline*.py", "**/*handler*.py"]:
        for f in sparse_ai_path.glob(pattern):
            if "__pycache__" not in str(f):
                test_files.append(f)

    # Also get some core files
    core_path = sparse_ai_path / "core"
    if core_path.exists():
        for f in core_path.glob("*.py"):
            if "__pycache__" not in str(f) and f not in test_files:
                test_files.append(f)

    # Limit to first 5 files
    test_files = test_files[:5]

    if not test_files:
        print("No Python files found!")
        # List what's available
        print("\nAvailable directories:")
        for d in sparse_ai_path.iterdir():
            if d.is_dir():
                print(f"  - {d.name}/")
        return

    print(f"\nFound {len(test_files)} files to test:")
    for f in test_files:
        print(f"  - {f.relative_to(sparse_ai_path)}")

    # Test each file
    for file_path in test_files:
        try:
            test_file(str(file_path))
        except Exception as e:
            print(f"\nERROR testing {file_path}: {e}")
            import traceback
            traceback.print_exc()

    print("\n" + "="*60)
    print("TESTING COMPLETE")
    print("="*60)


if __name__ == "__main__":
    main()
