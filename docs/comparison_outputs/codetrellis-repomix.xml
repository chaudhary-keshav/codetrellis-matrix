        """ErrorCollector should work with resilient_extract decorator."""

        class MockExtractor:
            @resilient_extract("IntegrationExtractor")
            def extract(self, content: str, file_path: str):
                if "error" in content:
                    raise ValueError("Found error in content")
                return {"parsed": True}

        extractor = MockExtractor()
        collector = ErrorCollector()

        files = [
            ("/good1.ts", "good content"),
            ("/bad.ts", "error content"),
            ("/good2.ts", "more good content"),
        ]

        results = []
        for path, content in files:
            result = extractor.extract(content, path)
            results.append(result)
            if not result.success:
                collector.add_error(path, "extract", Exception(result.errors[0]))

        # Should have 2 successes and 1 failure
        assert sum(1 for r in results if r.success) == 2
        assert sum(1 for r in results if not r.success) == 1
        assert collector.has_errors

    def test_codetrellis_error_chain(self):
        """Test error chaining from original exception to CodeTrellisError."""
        try:
            # Simulate original error
            original = KeyError("missing_key")
            raise ExtractionError(
                message="Failed to extract component",
                extractor_name="ComponentParser",
                file_path="/app.component.ts"
            ) from original
        except CodeTrellisError as e:
            assert "missing_key" in str(e.__cause__)
            assert e.code == CodeTrellisErrorCode.EXTRACTION_FAILED


