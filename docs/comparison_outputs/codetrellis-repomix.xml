        if hasattr(matrix, 'python_config_schemas') and matrix.python_config_schemas:
            lines.append("# Config")
            for cfg in matrix.python_config_schemas:
                framework = cfg.get('framework', '')
                lines.append(f"  {cfg['name']}|{framework}")

