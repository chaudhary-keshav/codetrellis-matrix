class ProjectScanner:
    """
    Scans entire project directory and builds a complete matrix.

    Usage:
        scanner = ProjectScanner()
        matrix = scanner.scan("/path/to/project")
    """

    # Default ignore patterns
    DEFAULT_IGNORE = {
        "node_modules",
        "dist",
        "build",
        ".git",
        ".angular",
        ".codetrellis",
        "__pycache__",
        ".pytest_cache",
        ".venv",
        "venv",
        "env",
        "signal_env",  # Custom venv patterns
        "*_env",  # Any *_env directory
        "site-packages",
        "coverage",
        ".nyc_output",
        "*.spec.ts",
        "*.test.ts",
        "*.spec.py",
        "*.test.py",
    }

    # File type mappings
    FILE_TYPES = {
        ".schema.ts": "schema",
        ".dto.ts": "dto",
        ".controller.ts": "controller",
        ".service.ts": "service",
        ".guard.ts": "guard",
        ".module.ts": "module",
        ".component.ts": "component",
        ".pipe.ts": "pipe",
        ".directive.ts": "directive",
        ".model.ts": "model",  # NEW: model files with interfaces/types
        ".store.ts": "store",  # NEW: signal stores
        ".routes.ts": "routes",  # NEW: Angular routes
        ".proto": "proto",
        ".py": "python",
    }

    def __init__(self, ignore_patterns: Optional[Set[str]] = None, parallel: bool = False, max_workers: Optional[int] = None):
        self.ignore_patterns = ignore_patterns or self.DEFAULT_IGNORE
        self.parsers = {}  # Will be populated with file parsers

        # v4.1.1: Parallel processing support
        self.parallel = parallel
        self.parallel_config = ParallelConfig(
            max_workers=max_workers,
            use_processes=False  # Use threads for shared state
        ) if parallel else None
        self.parallel_extractor = ParallelExtractor(self.parallel_config) if parallel else None
        self.error_collector = ErrorCollector()

        # Initialize v2.0 extractors
        self.interface_extractor = InterfaceExtractor()
        self.type_extractor = TypeExtractor()
        self.service_extractor = ServiceExtractor()
        self.store_extractor = StoreExtractor()
        self.route_extractor = RouteExtractor()
        self.websocket_extractor = WebSocketExtractor()
        self.http_api_extractor = HttpApiExtractor()

        # Phase 2: Context extractors
        self.jsdoc_extractor = JSDocExtractor()
        self.readme_extractor = ReadmeExtractor()
        self.config_extractor = ConfigExtractor()

        # v3.0: Error and TODO extractors
        self.error_extractor = ErrorExtractor()
        self.todo_extractor = TodoExtractor()

        # v2.1: Progress and Architecture extractors
        self.progress_extractor = ProgressExtractor()
        self.architecture_extractor = ArchitectureExtractor()

        # v3.1: Business Domain extractor
        self.business_domain_extractor = BusinessDomainExtractor()

        # v4.0: Python parser with all extractors
        self.python_parser = EnhancedPythonParser()

        # v4.1: Logic extractor for implementation details
        # Addresses: "AI can't see specific code logic"
        self.logic_extractor = LogicExtractor(max_body_lines=50, include_full_bodies=False)

    def scan(self, root_path: str) -> ProjectMatrix:
        """
        Scan entire project and build matrix.

        Args:
            root_path: Path to project root

        Returns:
            ProjectMatrix with all extracted information
        """
        root = Path(root_path).resolve()
        project_name = root.name

        print(f"[CodeTrellis] Scanning project: {project_name}")
        print(f"[CodeTrellis] Root path: {root}")

        matrix = ProjectMatrix(
            name=project_name,
            root_path=str(root)
        )

        # Walk through all files
        files_scanned = 0
        for file_path in self._walk_files(root):
            file_info = self._process_file(file_path, root)
            if file_info:
                matrix.files[file_info.relative_path] = file_info
                files_scanned += 1

                # Parse file based on type
                self._parse_file(file_path, file_info, matrix)

        matrix.total_files = files_scanned

        # Extract dependencies from package.json files
        self._extract_dependencies(root, matrix)

        # Detect services (NestJS modules)
        self._detect_services(root, matrix)

        # Phase 2: Extract context information
        self._extract_context(root, matrix)

        # v3.0: Extract error handling and TODOs
        self._extract_errors_and_todos(root, matrix)

        # v2.1: Extract project progress and overview
        self._extract_progress_and_overview(root, matrix)

        # v4.1: Extract implementation logic (addresses "AI can't see code logic")
        self._extract_logic(root, matrix)

        print(f"[CodeTrellis] Scan complete: {files_scanned} files processed")
        print(f"[CodeTrellis] Found: {len(matrix.schemas)} schemas, {len(matrix.dtos)} DTOs, "
              f"{len(matrix.controllers)} controllers, {len(matrix.components)} components")
        print(f"[CodeTrellis] v2.0: {len(matrix.interfaces)} interfaces, {len(matrix.types)} types, "
              f"{len(matrix.angular_services)} services, {len(matrix.stores)} stores")
        print(f"[CodeTrellis] v2.0: {len(matrix.routes)} route files, {len(matrix.websocket_events)} websocket files, "
              f"{len(matrix.http_apis)} http api files")
        print(f"[CodeTrellis] v3.0: {len(matrix.error_handling)} files with error handling, "
              f"{len(matrix.todos)} files with TODOs")

        # v4.0: Python-specific stats
        python_types = len(matrix.python_pydantic_models) + len(matrix.python_dataclasses) + len(matrix.python_typed_dicts)
        python_api = len(matrix.python_fastapi_endpoints) + len(matrix.python_flask_routes)
        python_ml = len(matrix.python_ml_models) + len(matrix.python_ml_trainers) + len(matrix.python_langchain_components)
        python_infra = len(matrix.python_mongodb_collections) + len(matrix.python_vector_stores) + len(matrix.python_redis_usage) + len(matrix.python_kafka_topics)

        if python_types > 0 or python_api > 0 or python_ml > 0:
            print(f"[CodeTrellis] v4.0 Python: {python_types} types, {python_api} API endpoints, "
                  f"{python_ml} ML components, {python_infra} infra")
            print(f"[CodeTrellis] v4.0 Python detail: {len(matrix.python_pydantic_models)} Pydantic, "
                  f"{len(matrix.python_dataclasses)} dataclasses, {len(matrix.python_fastapi_endpoints)} FastAPI, "
                  f"{len(matrix.python_functions)} functions")

        return matrix

    def _walk_files(self, root: Path):
        """Walk through all files, respecting ignore patterns"""
        for dirpath, dirnames, filenames in os.walk(root):
            # Filter out ignored directories
            dirnames[:] = [d for d in dirnames if not self._should_ignore(d)]

            for filename in filenames:
                if not self._should_ignore(filename):
                    yield Path(dirpath) / filename

    def _should_ignore(self, name: str) -> bool:
        """Check if file/directory should be ignored"""
        for pattern in self.ignore_patterns:
            if pattern.startswith("*") and pattern.endswith("*"):
                # *contains* pattern (e.g., *cache*)
                if pattern[1:-1] in name:
                    return True
            elif pattern.startswith("*"):
                # Ends with pattern (e.g., *.spec.ts)
                if name.endswith(pattern[1:]):
                    return True
            elif pattern.endswith("*"):
                # Starts with pattern (e.g., *_env for signal_env)
                if name.endswith(pattern[:-1]):
                    return True
            elif name == pattern:
                return True
        return False

    def _process_file(self, file_path: Path, root: Path) -> Optional[FileInfo]:
        """Process a single file and extract basic info"""
        try:
            stat = file_path.stat()
            content = file_path.read_bytes()

            # Determine file type
            file_type = "unknown"
            for pattern, ftype in self.FILE_TYPES.items():
                if file_path.name.endswith(pattern):
                    file_type = ftype
                    break

            return FileInfo(
                path=str(file_path),
                relative_path=str(file_path.relative_to(root)),
                extension=file_path.suffix,
                size=stat.st_size,
                hash=hashlib.md5(content).hexdigest()[:8],
                last_modified=datetime.fromtimestamp(stat.st_mtime),
                file_type=file_type
            )
        except Exception as e:
            print(f"[CodeTrellis] Warning: Could not process {file_path}: {e}")
            return None

