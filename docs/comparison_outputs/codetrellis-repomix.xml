        config = ParallelConfig(max_workers=2, use_processes=False)
        extractor = ParallelExtractor(config=config)

        result = extractor.extract_all(
            files=temp_files,
            extract_func=sample_extractor,
            extractor_name="TestExtractor"
        )

        for r in result.results:
            assert r.success
            assert "interfaces" in r.data
            assert "line_count" in r.data


