"""
CodeTrellis Error Handling Unit Tests
==============================

Tests for the error handling infrastructure introduced in v4.1.0.
Covers CodeTrellisErrorCode, CodeTrellisError, ExtractorResult, ErrorCollector, and resilient_extract.

Test IDs reference: CodeTrellis_V4.1_TESTING_CHECKLIST.md (T1.1 - T1.19)

Version: 4.1.0
Created: 2 February 2026
"""

import pytest
from datetime import datetime
from codetrellis.errors import (
    CodeTrellisErrorCode,
    CodeTrellisError,
    FileError,
    ParseError,
    ExtractionError,
    CompressionError,
    LSPError,
    ValidationError,
    ExtractorResult,
    ErrorCollector,
    resilient_extract
)


# =============================================================================
# CodeTrellisErrorCode Tests (T1.1 - T1.3)
# =============================================================================

class TestCodeTrellisErrorCode:
    """Tests for CodeTrellisErrorCode enum."""

    def test_t1_1_all_error_codes_have_unique_values(self):
        """T1.1: Verify all error codes have unique values."""
        values = [code.value for code in CodeTrellisErrorCode]
        assert len(values) == len(set(values)), "Duplicate error code values found"

    def test_t1_2_error_codes_follow_naming_convention(self):
        """T1.2: All error codes should follow EXXX pattern."""
        import re
        pattern = re.compile(r'^E\d{3}$')
        for code in CodeTrellisErrorCode:
            assert pattern.match(code.value), f"Error code {code.name} value '{code.value}' doesn't match EXXX pattern"

    def test_t1_3_error_categories_are_correctly_grouped(self):
        """T1.3: Error codes should be grouped by category."""
        category_ranges = {
            'general': ('E000', 'E099'),
            'file': ('E100', 'E199'),
            'parse': ('E200', 'E299'),
            'extraction': ('E300', 'E399'),
            'compression': ('E400', 'E499'),
            'lsp': ('E500', 'E599'),
            'plugin': ('E600', 'E699'),
            'validation': ('E700', 'E799'),
        }

        # Check that file errors are in E1XX range
        file_errors = [CodeTrellisErrorCode.FILE_NOT_FOUND, CodeTrellisErrorCode.FILE_READ_ERROR,
                       CodeTrellisErrorCode.FILE_WRITE_ERROR, CodeTrellisErrorCode.DIRECTORY_NOT_FOUND]
        for code in file_errors:
            code_num = int(code.value[1:])
            assert 100 <= code_num <= 199, f"{code.name} should be in file error range (E1XX)"

        # Check that parse errors are in E2XX range
        parse_errors = [CodeTrellisErrorCode.PARSE_ERROR, CodeTrellisErrorCode.SYNTAX_ERROR,
                        CodeTrellisErrorCode.INVALID_STRUCTURE]
        for code in parse_errors:
            code_num = int(code.value[1:])
            assert 200 <= code_num <= 299, f"{code.name} should be in parse error range (E2XX)"


# =============================================================================
# CodeTrellisError Tests (T1.4 - T1.7)
# =============================================================================

class TestCodeTrellisError:
    """Tests for CodeTrellisError exception class."""

    def test_t1_4_error_message_formatting_is_correct(self):
        """T1.4: Error message should include code and context."""
        error = CodeTrellisError(
            code=CodeTrellisErrorCode.FILE_NOT_FOUND,
            message="File missing",
            context={"path": "/test.ts"}
        )
        error_str = str(error)
        assert "[E100]" in error_str
        assert "File missing" in error_str
        assert "path: /test.ts" in error_str

    def test_t1_5_error_to_dict_serialization_works(self):
        """T1.5: Error should be serializable to dictionary."""
        error = CodeTrellisError(
            code=CodeTrellisErrorCode.PARSE_ERROR,
            message="Invalid syntax",
            context={"line": 42}
        )
        error_dict = error.to_dict()

        assert error_dict["code"] == "E200"
        assert error_dict["code_name"] == "PARSE_ERROR"
        assert error_dict["message"] == "Invalid syntax"
        assert error_dict["context"]["line"] == 42
        assert "timestamp" in error_dict

    def test_t1_6_error_timestamp_is_set_correctly(self):
        """T1.6: Error timestamp should be set at creation time."""
        before = datetime.now()
        error = CodeTrellisError(
            code=CodeTrellisErrorCode.UNKNOWN,
            message="Test error"
        )
        after = datetime.now()

        assert before <= error.timestamp <= after

    def test_t1_7_cause_exception_is_preserved(self):
        """T1.7: Original exception should be preserved as cause."""
        original = ValueError("Original error")
        error = CodeTrellisError(
            code=CodeTrellisErrorCode.EXTRACTION_FAILED,
            message="Extraction failed",
            cause=original
        )

        assert error.cause is original
        assert error.to_dict()["cause"] == "Original error"

    def test_error_without_context(self):
        """Error without context should have empty context dict."""
        error = CodeTrellisError(
            code=CodeTrellisErrorCode.UNKNOWN,
            message="Simple error"
        )
        assert error.context == {}
        assert "[E000]" in str(error)
        assert "Simple error" in str(error)

    def test_error_with_multiple_context_items(self):
        """Error with multiple context items should format correctly."""
        error = CodeTrellisError(
            code=CodeTrellisErrorCode.PARSE_ERROR,
            message="Parse failed",
            context={"file": "test.ts", "line": 10, "column": 5}
        )
        error_str = str(error)
        assert "file: test.ts" in error_str
        assert "line: 10" in error_str
        assert "column: 5" in error_str


# =============================================================================
# Specific Error Classes Tests
# =============================================================================

class TestSpecificErrorClasses:
    """Tests for specific error classes (FileError, ParseError, etc.)."""

    def test_file_error(self):
        """FileError should include path in context."""
        error = FileError(message="File not found", path="/missing/file.ts")
        assert error.code == CodeTrellisErrorCode.FILE_NOT_FOUND
        assert error.context["path"] == "/missing/file.ts"

    def test_parse_error_with_line(self):
        """ParseError should include file path and line number."""
        error = ParseError(
            message="Unexpected token",
            file_path="/src/app.ts",
            line=42
        )
        assert error.code == CodeTrellisErrorCode.PARSE_ERROR
        assert error.context["file_path"] == "/src/app.ts"
        assert error.context["line"] == 42

    def test_parse_error_without_line(self):
        """ParseError should work without line number."""
        error = ParseError(
            message="Invalid JSON",
            file_path="/config.json"
        )
        assert error.code == CodeTrellisErrorCode.PARSE_ERROR
        assert "line" not in error.context

