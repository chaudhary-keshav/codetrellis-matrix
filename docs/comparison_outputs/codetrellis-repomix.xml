)


class TestDataclassExtractor:
    """Tests for DataclassExtractor."""

    def test_basic_dataclass(self):
        content = '''
from dataclasses import dataclass

@dataclass
class User:
    name: str
    age: int
    email: str = ""
'''
        extractor = DataclassExtractor()
        result = extractor.extract(content)

