class TokenBudgetAllocator:
    def __init__(self, total_budget: int = 15000):
        self.budget = total_budget

    def allocate(self, project_stats: ProjectStats) -> Dict[str, int]:
        weights = {
            'interfaces': 0.25,
            'services': 0.20,
            'routes': 0.15,
            'components': 0.15,
            'business_domain': 0.10,
            'errors': 0.05,
            'todos': 0.05,
            'progress': 0.05,
        }

        # Adjust based on project characteristics
        if project_stats.is_api_heavy:
            weights['routes'] += 0.10
            weights['interfaces'] -= 0.05
            weights['components'] -= 0.05

        return {k: int(self.budget * v) for k, v in weights.items()}
