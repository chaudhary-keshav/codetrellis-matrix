  optional: boolean;
  readonly: boolean;
  documentation?: string;
}

interface MethodInfo {
  name: string;
  parameters: { name: string; type: string; optional: boolean }[];
  returnType: string;
  documentation?: string;
}

interface InterfaceInfo {
  name: string;
  filePath: string;
  exported: boolean;
