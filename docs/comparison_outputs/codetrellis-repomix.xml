    def _compress_python_infrastructure(self, matrix) -> List[str]:
        """Compress Python infrastructure (MongoDB, VectorDB, Redis, Kafka)"""
        lines = []

        # MongoDB Collections
        if hasattr(matrix, 'python_mongodb_collections') and matrix.python_mongodb_collections:
            lines.append("# MongoDB")
            for coll in matrix.python_mongodb_collections:
                doc_class = coll.get('document_class', '')
                indexes = coll.get('indexes', [])
