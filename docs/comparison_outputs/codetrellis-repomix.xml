        # Aggregate progress from all files
        src_path = root / 'src'
        if not src_path.exists():
            src_path = root

        all_file_progress = []
        total_markers = {'todos': 0, 'fixmes': 0, 'deprecated': 0, 'placeholders': 0}
        high_priority_items = []
        blockers = []

        # Scan TypeScript/Python files for progress markers
        extensions = ['*.ts', '*.tsx', '*.py', '*.js', '*.jsx']
        for ext in extensions:
            for file_path in src_path.rglob(ext):
                if self._should_ignore(file_path.name):
                    continue
                if 'node_modules' in str(file_path) or 'dist' in str(file_path):
                    continue

                try:
                    content = file_path.read_text(encoding='utf-8')
                    file_progress = self.progress_extractor.extract(content, str(file_path))

                    if file_progress.markers or file_progress.placeholders:
                        all_file_progress.append({
                            'file': str(file_path.relative_to(root)),
                            'status': file_progress.status.value,
                            'completion': file_progress.completion_estimate,
                            'todos': len(file_progress.todos),
                            'fixmes': len(file_progress.fixmes),
                            'placeholders': len(file_progress.placeholders),
                        })

                        # Aggregate totals
                        total_markers['todos'] += len(file_progress.todos)
                        total_markers['fixmes'] += len(file_progress.fixmes)
                        total_markers['deprecated'] += file_progress.deprecated_count
                        total_markers['placeholders'] += len(file_progress.placeholders)

                        # Collect high priority items
                        for marker in file_progress.markers:
                            if marker.priority in ('high', 'critical'):
                                high_priority_items.append(marker.to_dict())
                            if marker.marker_type.value == 'blocker':
                                blockers.append(marker.to_dict())

                except Exception:
                    pass

        # Calculate overall completion
        total_issues = (total_markers['todos'] + total_markers['fixmes'] +
                       total_markers['placeholders'])
        penalty = min(total_issues * 2, 50)
        overall_completion = max(100 - penalty, 50)

        # Sort files by completion (least complete first)
        all_file_progress.sort(key=lambda x: x.get('completion', 100))

        matrix.progress = {
            'completion': overall_completion,
            'summary': total_markers,
            'high_priority': high_priority_items[:10],  # Top 10
            'blockers': blockers[:5],  # Top 5
            'files': all_file_progress[:20],  # Top 20 files with issues
        }

        print(f"[CodeTrellis] v2.1: Extracted progress - {overall_completion}% complete, "
              f"{total_markers['todos']} TODOs, {total_markers['fixmes']} FIXMEs")

