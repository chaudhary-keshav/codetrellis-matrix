        temp_dir = tempfile.mkdtemp()
        try:
            config = StreamingConfig()
            extractor = StreamingExtractor(config)

            results = list(extractor.extract_stream(Path(temp_dir)))

            assert len(results) == 0
            assert extractor.stats.total_files == 0
        finally:
            shutil.rmtree(temp_dir)

    def test_unreadable_file(self):
        """Test handling of unreadable file."""
        temp_dir = tempfile.mkdtemp()
        try:
            # Create a file
            file_path = Path(temp_dir) / "test.py"
            file_path.write_text("def test(): pass")

            # Make it unreadable (Unix only)
            if os.name != 'nt':
                os.chmod(file_path, 0o000)

                config = StreamingConfig()
                extractor = StreamingExtractor(config)

                results = list(extractor.extract_stream(Path(temp_dir)))

                # Should handle gracefully
                if results:  # May be skipped due to permissions
                    assert not results[0].success or results[0].error is not None

                # Restore permissions for cleanup
                os.chmod(file_path, 0o644)
        finally:
            shutil.rmtree(temp_dir)

    def test_large_file_skipped(self):
        """Test that large files are skipped."""
        temp_dir = tempfile.mkdtemp()
        try:
            # Create a "large" file (set max to very small)
            file_path = Path(temp_dir) / "large.py"
            file_path.write_text("x" * 1000)  # 1KB

            config = StreamingConfig(max_file_size_mb=0.0001)  # ~100 bytes
            extractor = StreamingExtractor(config)

            results = list(extractor.extract_stream(Path(temp_dir)))

            # File should be skipped
            assert len(results) == 0
        finally:
            shutil.rmtree(temp_dir)
