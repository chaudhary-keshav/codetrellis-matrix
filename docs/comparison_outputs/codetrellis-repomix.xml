"""
CodeTrellis Parallel Processing Unit Tests
====================================

Tests for the parallel extraction module introduced in v4.1.0.
Addresses Report 2 Section 3.2 (HIGH: No Parallel Processing).

Version: 4.1.0
Created: 2 February 2026
"""

import pytest
import tempfile
import os
from pathlib import Path
from codetrellis.parallel import (
    ParallelConfig,
    ParallelResult,
    ParallelExtractor,
    AsyncParallelExtractor,
    merge_extraction_results,
    _get_worker_count,
    _extract_single_file
)
from codetrellis.errors import ExtractorResult


# =============================================================================
# Test Fixtures
# =============================================================================

@pytest.fixture
def temp_files():
    """Create temporary files for testing."""
    with tempfile.TemporaryDirectory() as tmpdir:
        files = []
        for i in range(5):
            file_path = Path(tmpdir) / f"test_{i}.ts"
            file_path.write_text(f"// File {i}\nexport interface Test{i} {{ id: number; }}")
            files.append(file_path)
        yield files


@pytest.fixture
def sample_extractor():
    """Simple extractor function for testing."""
    def extract(content: str, file_path: str):
        # Simulate extraction
        return {
            "interfaces": [f"Interface from {Path(file_path).name}"],
            "line_count": len(content.split('\n'))
        }
    return extract


@pytest.fixture
def failing_extractor():
    """Extractor that fails on certain files."""
    def extract(content: str, file_path: str):
        if "error" in content.lower():
            raise ValueError("Found error keyword in content")
        return {"parsed": True}
    return extract


# =============================================================================
# ParallelConfig Tests
# =============================================================================

class TestParallelConfig:
    """Tests for ParallelConfig dataclass."""

    def test_default_config(self):
        """Default config should have sensible defaults."""
        config = ParallelConfig()
        assert config.max_workers is None  # Use cpu_count
        assert config.chunk_size == 10
        assert config.timeout_per_file == 30.0
        assert config.use_processes is True

    def test_custom_config(self):
        """Custom config values should be respected."""
        config = ParallelConfig(
            max_workers=4,
            chunk_size=20,
            timeout_per_file=60.0,
            use_processes=False
        )
        assert config.max_workers == 4
        assert config.chunk_size == 20
        assert config.timeout_per_file == 60.0
        assert config.use_processes is False


# =============================================================================
# Worker Count Tests
# =============================================================================

class TestGetWorkerCount:
    """Tests for _get_worker_count function."""

    def test_explicit_worker_count(self):
        """Should use explicit worker count if provided."""
        config = ParallelConfig(max_workers=4)
        assert _get_worker_count(config) == 4

    def test_auto_worker_count(self):
        """Should auto-detect based on CPU count."""
        config = ParallelConfig(max_workers=None)
        count = _get_worker_count(config)
        assert count >= 1
        # Should be at most cpu_count - 1
        cpu_count = os.cpu_count() or 4
        assert count <= cpu_count


# =============================================================================
# Single File Extraction Tests
# =============================================================================

class TestExtractSingleFile:
    """Tests for _extract_single_file function."""

    def test_successful_extraction(self, temp_files, sample_extractor):
        """Should return success result for valid file."""
        args = (temp_files[0], sample_extractor, "TestExtractor")
        result = _extract_single_file(args)

        assert isinstance(result, ExtractorResult)
        assert result.success is True
        assert result.extractor_name == "TestExtractor"
        assert "interfaces" in result.data

    def test_file_not_found(self, sample_extractor):
        """Should return failure for non-existent file."""
        args = (Path("/nonexistent/file.ts"), sample_extractor, "TestExtractor")
        result = _extract_single_file(args)

        assert isinstance(result, ExtractorResult)
        assert result.success is False
        assert "File not found" in result.errors[0]

    def test_extraction_exception(self, temp_files, failing_extractor):
        """Should handle extraction exceptions gracefully."""
        # Create a file with error content
        error_file = temp_files[0].parent / "error_file.ts"
        error_file.write_text("// This file contains ERROR")

        args = (error_file, failing_extractor, "FailExtractor")
        result = _extract_single_file(args)

        assert isinstance(result, ExtractorResult)
        assert result.success is False
        assert len(result.errors) > 0


# =============================================================================
# ParallelExtractor Tests
# =============================================================================

class TestParallelExtractor:
    """Tests for ParallelExtractor class."""

    def test_initialization(self):
        """Should initialize with config."""
        config = ParallelConfig(max_workers=2)
        extractor = ParallelExtractor(config=config)
        assert extractor.worker_count == 2

    def test_extract_empty_files(self, sample_extractor):
        """Should handle empty file list."""
        extractor = ParallelExtractor()
        result = extractor.extract_all(
            files=[],
            extract_func=sample_extractor,
            extractor_name="TestExtractor"
        )

        assert isinstance(result, ParallelResult)
        assert result.total_files == 0
        assert result.successful == 0
        assert result.failed == 0
        assert result.duration_seconds == 0.0

    def test_extract_multiple_files(self, temp_files, sample_extractor):
        """Should extract from multiple files in parallel."""
        # Use threads instead of processes for faster tests
        config = ParallelConfig(max_workers=2, use_processes=False)
        extractor = ParallelExtractor(config=config)

        result = extractor.extract_all(
            files=temp_files,
            extract_func=sample_extractor,
            extractor_name="TestExtractor"
        )

        assert isinstance(result, ParallelResult)
        assert result.total_files == 5
        assert result.successful == 5
        assert result.failed == 0
        assert result.duration_seconds > 0
        assert len(result.results) == 5

    def test_extract_with_failures(self, temp_files, failing_extractor):
        """Should handle partial failures gracefully."""
        # Create one file with error content
        error_file = temp_files[0].parent / "error_file.ts"
        error_file.write_text("// ERROR content")

        files = temp_files + [error_file]

        config = ParallelConfig(max_workers=2, use_processes=False)
        extractor = ParallelExtractor(config=config)

        result = extractor.extract_all(
            files=files,
            extract_func=failing_extractor,
            extractor_name="TestExtractor"
        )

        assert result.total_files == 6
        assert result.successful == 5
        assert result.failed == 1
        assert result.errors.has_errors

    def test_error_collector_populated(self, temp_files, failing_extractor):
        """ErrorCollector should contain failure details."""
        error_file = temp_files[0].parent / "error_file.ts"
        error_file.write_text("// ERROR content")

        config = ParallelConfig(max_workers=2, use_processes=False)
        extractor = ParallelExtractor(config=config)

        result = extractor.extract_all(
            files=[error_file],
            extract_func=failing_extractor,
            extractor_name="TestExtractor"
        )

        assert result.errors.has_errors
        summary = result.errors.summary()
        assert "error_file.ts" in summary


# =============================================================================
# AsyncParallelExtractor Tests
# =============================================================================

# Check if pytest-asyncio is available
try:
    import pytest_asyncio
    HAS_ASYNCIO = True
except ImportError:
    HAS_ASYNCIO = False


@pytest.mark.skipif(not HAS_ASYNCIO, reason="pytest-asyncio not installed")
class TestAsyncParallelExtractor:
    """Tests for AsyncParallelExtractor class."""

    @pytest.mark.asyncio
    async def test_async_extract_empty(self, sample_extractor):
        """Should handle empty file list asynchronously."""
        extractor = AsyncParallelExtractor()
        result = await extractor.extract_all_async(
            files=[],
            extract_func=sample_extractor,
            extractor_name="TestExtractor"
        )

        assert result.total_files == 0
        assert result.successful == 0

    @pytest.mark.asyncio
    async def test_async_extract_multiple(self, temp_files, sample_extractor):
        """Should extract from multiple files asynchronously."""
        config = ParallelConfig(max_workers=2, use_processes=False)
        extractor = AsyncParallelExtractor(config=config)

        result = await extractor.extract_all_async(
            files=temp_files,
            extract_func=sample_extractor,
            extractor_name="TestExtractor"
        )

        assert result.total_files == 5
        assert result.successful == 5
        assert len(result.results) == 5


# =============================================================================
# Merge Results Tests
# =============================================================================

class TestMergeExtractionResults:
    """Tests for merge_extraction_results function."""

    def test_merge_empty(self):
        """Should handle empty results list."""
        merged = merge_extraction_results([])
        assert merged["interfaces"] == []
        assert merged["types"] == []

    def test_merge_single_result(self):
        """Should handle single result."""
        results = [{"interfaces": ["User"], "types": ["UserId"]}]
        merged = merge_extraction_results(results)

        assert merged["interfaces"] == ["User"]
        assert merged["types"] == ["UserId"]

    def test_merge_multiple_results(self):
        """Should merge multiple results correctly."""
        results = [
            {"interfaces": ["User"], "types": ["UserId"], "components": ["AppComponent"]},
            {"interfaces": ["Product"], "types": ["ProductId"], "services": ["DataService"]},
            {"interfaces": ["Order"], "routes": ["/orders"]},
        ]
        merged = merge_extraction_results(results)

        assert merged["interfaces"] == ["User", "Product", "Order"]
        assert merged["types"] == ["UserId", "ProductId"]
        assert merged["components"] == ["AppComponent"]
        assert merged["services"] == ["DataService"]
        assert merged["routes"] == ["/orders"]

    def test_merge_handles_missing_keys(self):
        """Should handle results with missing keys."""
        results = [
            {"interfaces": ["User"]},
            {"components": ["AppComponent"]},
        ]
        merged = merge_extraction_results(results)

        assert merged["interfaces"] == ["User"]
        assert merged["components"] == ["AppComponent"]
        assert merged["types"] == []


# =============================================================================
# Integration Tests
# =============================================================================

class TestParallelIntegration:
    """Integration tests for parallel extraction."""

    def test_parallel_result_metrics(self, temp_files, sample_extractor):
        """ParallelResult should have accurate metrics."""
        config = ParallelConfig(max_workers=2, use_processes=False)
        extractor = ParallelExtractor(config=config)

        result = extractor.extract_all(
            files=temp_files,
            extract_func=sample_extractor,
