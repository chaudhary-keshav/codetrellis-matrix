#!/usr/bin/env python3
"""
Test InterfaceExtractor and TypeExtractor on real trading-ui files
"""

import sys
sys.path.insert(0, '/Users/keshavchaudhary/Documents/GitHub/ns-brain/tools/codetrellis')

from pathlib import Path
from codetrellis.extractors import InterfaceExtractor, TypeExtractor

TRADING_UI_PATH = Path('/Users/keshavchaudhary/Documents/GitHub/ns-brain/ai/trading-ui/src/app')

def test_model_files():
    """Test extraction on model files"""
    models_dir = TRADING_UI_PATH / 'models'

    print("=" * 60)
    print("TESTING EXTRACTORS ON TRADING-UI MODEL FILES")
    print("=" * 60)

    interface_extractor = InterfaceExtractor()
    type_extractor = TypeExtractor()

    total_interfaces = 0
    total_types = 0

    for ts_file in models_dir.glob('*.ts'):
        if ts_file.name == 'index.ts':
            continue

        content = ts_file.read_text()

        interfaces = interface_extractor.extract(content)
        types = type_extractor.extract(content)

        total_interfaces += len(interfaces)
        total_types += len(types)

        print(f"\n📁 {ts_file.name}")
        print("-" * 40)

        if interfaces:
            print(f"  Interfaces ({len(interfaces)}):")
            for iface in interfaces:
                extends_str = f" extends {', '.join(iface.extends)}" if iface.extends else ""
                export_str = "export " if iface.is_exported else ""
                props_count = len(iface.properties)
                methods_count = len(iface.methods)
                print(f"    • {export_str}interface {iface.name}{extends_str}")
                print(f"      Properties: {props_count}, Methods: {methods_count}")

                # Show first 3 properties
                for prop in iface.properties[:3]:
                    opt = "?" if prop.optional else ""
                    ro = "readonly " if prop.readonly else ""
                    print(f"        - {ro}{prop.name}{opt}: {prop.type}")
                if len(iface.properties) > 3:
                    print(f"        ... and {len(iface.properties) - 3} more")

        if types:
            print(f"  Type Aliases ({len(types)}):")
            for t in types:
                export_str = "export " if t.is_exported else ""
                type_preview = t.type[:50] if len(t.type) > 50 else t.type
                print(f"    • {export_str}type {t.name} = {type_preview}{'...' if len(t.type) > 50 else ''}")
                print(f"      Kind: {t.kind}")

    print("\n" + "=" * 60)
    print(f"SUMMARY")
    print(f"  Total Interfaces: {total_interfaces}")
    print(f"  Total Type Aliases: {total_types}")
    print("=" * 60)

    return total_interfaces, total_types

def test_codetrellis_format_output():
    """Test CodeTrellis format output"""
    print("\n" + "=" * 60)
    print("TESTING CodeTrellis FORMAT OUTPUT")
    print("=" * 60)

    interface_extractor = InterfaceExtractor()
    type_extractor = TypeExtractor()

    # Read one model file
    signal_model = TRADING_UI_PATH / 'models' / 'signal.model.ts'
    content = signal_model.read_text()

    interfaces = interface_extractor.extract(content)
    types = type_extractor.extract(content)

    codetrellis_interfaces = interface_extractor.to_codetrellis_format(interfaces)
    codetrellis_types = type_extractor.to_codetrellis_format(types)

    print("\n📄 CodeTrellis Output for signal.model.ts:")
    print("-" * 40)

    print(codetrellis_interfaces)

    print()

    print(codetrellis_types)

def test_services():
