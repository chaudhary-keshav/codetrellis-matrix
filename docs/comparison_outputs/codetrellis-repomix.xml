<file path="tests/fixtures/services/simple.service.ts">
import { HttpClient, HttpErrorResponse, HttpParams } from '@angular/common/http';
import { Injectable, inject } from '@angular/core';
import { BehaviorSubject, Observable, Subject, of, throwError } from 'rxjs';
import { catchError, map, retry, shareReplay, tap } from 'rxjs/operators';
import { environment } from '../../../environments/environment';

/**
 * TradingService - Handles all trading-related API calls
 * Tests service parser with full HTTP methods, observables, and error handling
 */
@Injectable({
  providedIn: 'root',
})
export class TradingService {
  private readonly http = inject(HttpClient);
  private readonly baseUrl = `${environment.apiUrl}/api/v1/trading`;

  // Cached observables for frequently accessed data
  private readonly positionsCache$ = new BehaviorSubject<Position[] | null>(null);
  private readonly ordersCache$ = new BehaviorSubject<Order[] | null>(null);

  // Event streams
  private readonly orderExecuted$ = new Subject<Order>();
  private readonly positionUpdated$ = new Subject<Position>();
  private readonly error$ = new Subject<ServiceError>();

  // Public observables
  readonly onOrderExecuted$: Observable<Order> = this.orderExecuted$.asObservable();
  readonly onPositionUpdated$: Observable<Position> = this.positionUpdated$.asObservable();
  readonly onError$: Observable<ServiceError> = this.error$.asObservable();

  // ===== POSITIONS API =====

  /**
   * Get all positions for the current user
   */
  getPositions(options?: GetPositionsOptions): Observable<Position[]> {
    let params = new HttpParams();

    if (options?.accountId) {
      params = params.set('accountId', options.accountId);
    }
    if (options?.symbols) {
      params = params.set('symbols', options.symbols.join(','));
    }
    if (options?.includeHistory) {
      params = params.set('includeHistory', options.includeHistory.toString());
    }

    return this.http.get<ApiResponse<Position[]>>(`${this.baseUrl}/positions`, { params }).pipe(
      map((response) => response.data),
      tap((positions) => this.positionsCache$.next(positions)),
      catchError((error) => this.handleError(error, 'getPositions')),
    );
  }

  /**
   * Get a single position by ID
   */
  getPositionById(id: string): Observable<Position> {
    return this.http.get<ApiResponse<Position>>(`${this.baseUrl}/positions/${id}`).pipe(
      map((response) => response.data),
      catchError((error) => this.handleError(error, 'getPositionById')),
    );
  }

  /**
   * Get position by symbol
   */
  getPositionBySymbol(symbol: string): Observable<Position | null> {
    return this.http.get<ApiResponse<Position>>(`${this.baseUrl}/positions/symbol/${symbol}`).pipe(
      map((response) => response.data),
      catchError(() => of(null)),
    );
  }

  /**
   * Search positions with query
   */
  searchPositions(query: string): Observable<Position[]> {
    const params = new HttpParams().set('q', query);
    return this.http
      .get<ApiResponse<Position[]>>(`${this.baseUrl}/positions/search`, { params })
      .pipe(
        map((response) => response.data),
        catchError((error) => this.handleError(error, 'searchPositions')),
      );
  }

  /**
   * Close a position
   */
  closePosition(
    positionId: string,
    options?: ClosePositionOptions,
  ): Observable<ClosePositionResult> {
    const body = {
      quantity: options?.quantity,
      orderType: options?.orderType ?? 'MARKET',
      limitPrice: options?.limitPrice,
    };

    return this.http
      .post<ApiResponse<ClosePositionResult>>(`${this.baseUrl}/positions/${positionId}/close`, body)
      .pipe(
        map((response) => response.data),
        tap(() => {
          // Invalidate cache
          const current = this.positionsCache$.value;
          if (current) {
            this.positionsCache$.next(current.filter((p) => p.id !== positionId));
          }
        }),
        catchError((error) => this.handleError(error, 'closePosition')),
      );
  }

  /**
   * Export positions to file
   */
  exportPositions(positions: Position[], format: ExportFormat): Observable<ExportResult> {
    const body = { positionIds: positions.map((p) => p.id), format };
    return this.http.post<ApiResponse<ExportResult>>(`${this.baseUrl}/positions/export`, body).pipe(
      map((response) => response.data),
      catchError((error) => this.handleError(error, 'exportPositions')),
    );
  }

  // ===== ORDERS API =====

  /**
   * Get all orders with pagination
   */
  getOrders(options?: GetOrdersOptions): Observable<PaginatedResponse<Order>> {
    let params = new HttpParams()
      .set('page', (options?.page ?? 1).toString())
      .set('pageSize', (options?.pageSize ?? 25).toString());

    if (options?.status) {
      params = params.set('status', options.status);
    }
    if (options?.symbol) {
      params = params.set('symbol', options.symbol);
    }
    if (options?.dateFrom) {
      params = params.set('dateFrom', options.dateFrom.toISOString());
    }
    if (options?.dateTo) {
      params = params.set('dateTo', options.dateTo.toISOString());
    }

    return this.http
      .get<ApiResponse<PaginatedResponse<Order>>>(`${this.baseUrl}/orders`, { params })
      .pipe(
        map((response) => response.data),
        catchError((error) => this.handleError(error, 'getOrders')),
      );
  }

  /**
   * Get order by ID
   */
  getOrderById(orderId: string): Observable<Order> {
    return this.http.get<ApiResponse<Order>>(`${this.baseUrl}/orders/${orderId}`).pipe(
      map((response) => response.data),
      catchError((error) => this.handleError(error, 'getOrderById')),
    );
  }

  /**
   * Place a new order
   */
  placeOrder(request: CreateOrderRequest): Observable<Order> {
    return this.http.post<ApiResponse<Order>>(`${this.baseUrl}/orders`, request).pipe(
      map((response) => response.data),
      tap((order) => this.orderExecuted$.next(order)),
      catchError((error) => this.handleError(error, 'placeOrder')),
    );
  }

  /**
   * Place multiple orders in batch
   */
  placeOrdersBatch(requests: CreateOrderRequest[]): Observable<BatchOrderResult> {
    return this.http
      .post<ApiResponse<BatchOrderResult>>(`${this.baseUrl}/orders/batch`, { orders: requests })
      .pipe(
        map((response) => response.data),
        catchError((error) => this.handleError(error, 'placeOrdersBatch')),
      );
  }

  /**
   * Modify an existing order
   */
  modifyOrder(orderId: string, modifications: ModifyOrderRequest): Observable<Order> {
    return this.http
      .patch<ApiResponse<Order>>(`${this.baseUrl}/orders/${orderId}`, modifications)
      .pipe(
        map((response) => response.data),
        catchError((error) => this.handleError(error, 'modifyOrder')),
      );
  }

  /**
   * Cancel an order
   */
  cancelOrder(orderId: string): Observable<void> {
    return this.http
      .delete<void>(`${this.baseUrl}/orders/${orderId}`)
      .pipe(catchError((error) => this.handleError(error, 'cancelOrder')));
  }

  /**
   * Cancel multiple orders
   */
  cancelOrdersBatch(orderIds: string[]): Observable<BatchCancelResult> {
    return this.http
      .post<ApiResponse<BatchCancelResult>>(`${this.baseUrl}/orders/cancel-batch`, { orderIds })
      .pipe(
        map((response) => response.data),
        catchError((error) => this.handleError(error, 'cancelOrdersBatch')),
      );
  }

  /**
   * Cancel all open orders for a symbol
   */
  cancelAllOrdersForSymbol(symbol: string): Observable<void> {
    return this.http
      .delete<void>(`${this.baseUrl}/orders/symbol/${symbol}`)
      .pipe(catchError((error) => this.handleError(error, 'cancelAllOrdersForSymbol')));
  }

  // ===== MARKET DATA API =====

  /**
   * Get current quote for a symbol
   */
  getQuote(symbol: string): Observable<Quote> {
    return this.http.get<ApiResponse<Quote>>(`${this.baseUrl}/market-data/quote/${symbol}`).pipe(
      map((response) => response.data),
      retry(2),
      catchError((error) => this.handleError(error, 'getQuote')),
    );
  }

  /**
   * Get quotes for multiple symbols
   */
  getQuotes(symbols: string[]): Observable<Record<string, Quote>> {
    const params = new HttpParams().set('symbols', symbols.join(','));
    return this.http
      .get<ApiResponse<Record<string, Quote>>>(`${this.baseUrl}/market-data/quotes`, { params })
      .pipe(
        map((response) => response.data),
        catchError((error) => this.handleError(error, 'getQuotes')),
      );
  }

  /**
   * Get historical OHLCV data
   */
  getHistoricalData(
    symbol: string,
    timeframe: Timeframe,
    options?: HistoricalDataOptions,
  ): Observable<OHLCV[]> {
    let params = new HttpParams().set('timeframe', timeframe);

    if (options?.from) params = params.set('from', options.from.toISOString());
    if (options?.to) params = params.set('to', options.to.toISOString());
    if (options?.limit) params = params.set('limit', options.limit.toString());

    return this.http
      .get<ApiResponse<OHLCV[]>>(`${this.baseUrl}/market-data/historical/${symbol}`, { params })
      .pipe(
        map((response) => response.data),
        catchError((error) => this.handleError(error, 'getHistoricalData')),
      );
  }

  // ===== ACCOUNT API =====

  /**
   * Get account summary
   */
  getAccountSummary(accountId: string): Observable<AccountSummary> {
    return this.http
      .get<ApiResponse<AccountSummary>>(`${this.baseUrl}/accounts/${accountId}/summary`)
      .pipe(
        map((response) => response.data),
        shareReplay({ bufferSize: 1, refCount: true }),
        catchError((error) => this.handleError(error, 'getAccountSummary')),
      );
  }

  /**
   * Get account balance history
   */
  getBalanceHistory(accountId: string, days: number = 30): Observable<BalanceHistoryPoint[]> {
    const params = new HttpParams().set('days', days.toString());
    return this.http
      .get<
        ApiResponse<BalanceHistoryPoint[]>
      >(`${this.baseUrl}/accounts/${accountId}/balance-history`, { params })
      .pipe(
        map((response) => response.data),
        catchError((error) => this.handleError(error, 'getBalanceHistory')),
      );
  }

  // ===== TRADES API =====

  /**
   * Get trade history
   */
  getTradeHistory(options?: GetTradesOptions): Observable<PaginatedResponse<Trade>> {
    let params = new HttpParams()
      .set('page', (options?.page ?? 1).toString())
      .set('pageSize', (options?.pageSize ?? 50).toString());

    if (options?.symbol) params = params.set('symbol', options.symbol);
    if (options?.dateFrom) params = params.set('dateFrom', options.dateFrom.toISOString());
    if (options?.dateTo) params = params.set('dateTo', options.dateTo.toISOString());

    return this.http
      .get<ApiResponse<PaginatedResponse<Trade>>>(`${this.baseUrl}/trades`, { params })
      .pipe(
        map((response) => response.data),
        catchError((error) => this.handleError(error, 'getTradeHistory')),
      );
  }

  // ===== PRIVATE HELPERS =====

  /**
   * Standard error handler
   */
  private handleError(error: HttpErrorResponse, operation: string): Observable<never> {
    let message: string;

    if (error.error instanceof ErrorEvent) {
      // Client-side error
      message = error.error.message;
    } else {
      // Server-side error
      message = error.error?.message ?? `Error ${error.status}: ${error.statusText}`;
    }

    const serviceError: ServiceError = {
      operation,
      message,
      statusCode: error.status,
      timestamp: new Date(),
    };

    this.error$.next(serviceError);
    console.error(`TradingService.${operation}:`, serviceError);

    return throwError(() => new Error(message));
  }

  /**
   * Refresh positions cache
   */
  refreshPositionsCache(): void {
    this.getPositions().subscribe();
  }

  /**
   * Clear all caches
   */
  clearCaches(): void {
    this.positionsCache$.next(null);
    this.ordersCache$.next(null);
  }
}

// ===== TYPE DEFINITIONS =====

interface ApiResponse<T> {
  success: boolean;
  data: T;
  message?: string;
  timestamp: string;
}

interface PaginatedResponse<T> {
  items: T[];
  page: number;
  pageSize: number;
  totalItems: number;
  totalPages: number;
  hasNext: boolean;
  hasPrevious: boolean;
}

interface Position {
  id: string;
  symbol: string;
  quantity: number;
  averagePrice: number;
  currentPrice: number;
  marketValue: number;
  costBasis: number;
  unrealizedPnL: number;
  unrealizedPnLPercent: number;
  side: 'LONG' | 'SHORT';
  openedAt: Date;
  lastUpdated: Date;
}

interface Order {
  id: string;
  symbol: string;
  side: 'BUY' | 'SELL';
  orderType: 'MARKET' | 'LIMIT' | 'STOP' | 'STOP_LIMIT';
  quantity: number;
  filledQuantity: number;
  limitPrice?: number;
  stopPrice?: number;
  status: 'PENDING' | 'OPEN' | 'PARTIALLY_FILLED' | 'FILLED' | 'CANCELLED' | 'REJECTED';
  timeInForce: 'DAY' | 'GTC' | 'IOC' | 'FOK';
  createdAt: Date;
  updatedAt: Date;
}

interface Trade {
  id: string;
  orderId: string;
  symbol: string;
  side: 'BUY' | 'SELL';
  quantity: number;
  price: number;
  commission: number;
  executedAt: Date;
}

interface Quote {
  symbol: string;
  bid: number;
  ask: number;
  last: number;
  volume: number;
  change: number;
  changePercent: number;
  timestamp: Date;
}

interface OHLCV {
  timestamp: Date;
  open: number;
  high: number;
  low: number;
  close: number;
  volume: number;
}

interface AccountSummary {
  accountId: string;
  balance: number;
  equity: number;
  buyingPower: number;
  margin: number;
  unrealizedPnL: number;
  realizedPnL: number;
  totalPositions: number;
  openOrdersCount: number;
}

interface BalanceHistoryPoint {
  date: Date;
  balance: number;
  equity: number;
  dailyPnL: number;
}

// Options interfaces
interface GetPositionsOptions {
  accountId?: string;
  symbols?: string[];
  includeHistory?: boolean;
}

interface ClosePositionOptions {
  quantity?: number;
  orderType?: 'MARKET' | 'LIMIT';
  limitPrice?: number;
}

interface ClosePositionResult {
  positionId: string;
  closedQuantity: number;
  realizedPnL: number;
  orderId: string;
}

interface GetOrdersOptions {
  page?: number;
  pageSize?: number;
  status?: 'PENDING' | 'OPEN' | 'FILLED' | 'CANCELLED';
  symbol?: string;
  dateFrom?: Date;
  dateTo?: Date;
}

interface CreateOrderRequest {
  symbol: string;
  side: 'BUY' | 'SELL';
  orderType: 'MARKET' | 'LIMIT' | 'STOP' | 'STOP_LIMIT';
  quantity: number;
  limitPrice?: number;
  stopPrice?: number;
  timeInForce?: 'DAY' | 'GTC' | 'IOC' | 'FOK';
}

interface ModifyOrderRequest {
  quantity?: number;
  limitPrice?: number;
  stopPrice?: number;
}

interface BatchOrderResult {
  successful: Order[];
  failed: { request: CreateOrderRequest; error: string }[];
}

interface BatchCancelResult {
  successful: string[];
  failed: { orderId: string; error: string }[];
}

interface HistoricalDataOptions {
  from?: Date;
  to?: Date;
  limit?: number;
}

interface GetTradesOptions {
  page?: number;
  pageSize?: number;
  symbol?: string;
  dateFrom?: Date;
  dateTo?: Date;
}

interface ServiceError {
  operation: string;
  message: string;
  statusCode: number;
  timestamp: Date;
}

interface ExportResult {
  url: string;
  format: string;
  rowCount: number;
  expiresAt: Date;
}

type ExportFormat = 'csv' | 'xlsx' | 'json';
type Timeframe = '1m' | '5m' | '15m' | '30m' | '1H' | '4H' | '1D' | '1W' | '1M';

// Export types for consumers
export type {
  AccountSummary,
  ClosePositionResult,
  CreateOrderRequest,
  ExportFormat,
  ModifyOrderRequest,
  OHLCV,
  Order,
  Position,
  Quote,
  ServiceError,
  Timeframe,
  Trade,
};
</file>

<file path="tests/fixtures/stores/simple.store.ts">
import { computed, inject } from '@angular/core';
import { tapResponse } from '@ngrx/operators';
import {
  patchState,
  signalStore,
  withComputed,
  withHooks,
  withMethods,
  withState,
} from '@ngrx/signals';
import { rxMethod } from '@ngrx/signals/rxjs-interop';
import { debounceTime, distinctUntilChanged, pipe, switchMap, tap } from 'rxjs';
import { TradingService } from '../../services/trading.service';

// State interface
interface PortfolioState {
  // Core data
  positions: Position[];
  selectedPosition: Position | null;

  // Pagination
  page: number;
  pageSize: number;
  totalItems: number;

  // Loading states
  isLoading: boolean;
  isRefreshing: boolean;

  // Error state
  error: string | null;

  // Filters
  filters: PortfolioFilters;

  // UI state
  sortField: string;
  sortDirection: 'asc' | 'desc';

  // Last update timestamp
  lastUpdated: Date | null;
}

// Initial state
const initialState: PortfolioState = {
  positions: [],
  selectedPosition: null,
  page: 1,
  pageSize: 25,
  totalItems: 0,
  isLoading: false,
  isRefreshing: false,
  error: null,
  filters: {
    symbols: [],
    minPnL: null,
    maxPnL: null,
    status: 'all',
  },
  sortField: 'symbol',
  sortDirection: 'asc',
  lastUpdated: null,
};

export const PortfolioStore = signalStore(
  { providedIn: 'root' },

  withState(initialState),

  withComputed((state) => ({
    // Count computeds
    positionCount: computed(() => state.positions().length),
    hasPositions: computed(() => state.positions().length > 0),

    // Aggregation computeds
    totalPnL: computed(() => state.positions().reduce((sum, p) => sum + p.unrealizedPnL, 0)),
    totalValue: computed(() => state.positions().reduce((sum, p) => sum + p.marketValue, 0)),
    totalCost: computed(() => state.positions().reduce((sum, p) => sum + p.costBasis, 0)),

    // Performance metrics
    winningPositions: computed(() => state.positions().filter((p) => p.unrealizedPnL > 0)),
    losingPositions: computed(() => state.positions().filter((p) => p.unrealizedPnL < 0)),
    winRate: computed(() => {
      const positions = state.positions();
      if (positions.length === 0) return 0;
      const winners = positions.filter((p) => p.unrealizedPnL > 0).length;
      return (winners / positions.length) * 100;
    }),

    // Filtered positions
    filteredPositions: computed(() => {
      const positions = state.positions();
      const filters = state.filters();

      return positions.filter((p) => {
        if (filters.symbols.length > 0 && !filters.symbols.includes(p.symbol)) {
          return false;
        }
        if (filters.minPnL !== null && p.unrealizedPnL < filters.minPnL) {
          return false;
        }
        if (filters.maxPnL !== null && p.unrealizedPnL > filters.maxPnL) {
          return false;
        }
        if (filters.status !== 'all') {
          if (filters.status === 'winning' && p.unrealizedPnL <= 0) return false;
          if (filters.status === 'losing' && p.unrealizedPnL >= 0) return false;
        }
        return true;
      });
    }),

    // Sorted positions
    sortedPositions: computed(() => {
      const positions = state.filteredPositions ? state.filteredPositions() : state.positions();
      const field = state.sortField();
      const direction = state.sortDirection();

      return [...positions].sort((a, b) => {
        const aVal = a[field as keyof Position];
        const bVal = b[field as keyof Position];
        const comparison = aVal < bVal ? -1 : aVal > bVal ? 1 : 0;
        return direction === 'asc' ? comparison : -comparison;
      });
    }),

    // Paginated positions
    paginatedPositions: computed(() => {
      const positions = state.sortedPositions ? state.sortedPositions() : state.positions();
      const page = state.page();
      const pageSize = state.pageSize();
      const start = (page - 1) * pageSize;
      return positions.slice(start, start + pageSize);
    }),

    // Pagination helpers
    totalPages: computed(() => {
      const filtered = state.filteredPositions ? state.filteredPositions() : state.positions();
      return Math.ceil(filtered.length / state.pageSize());
    }),
    hasNextPage: computed(() => {
      const filtered = state.filteredPositions ? state.filteredPositions() : state.positions();
      return state.page() * state.pageSize() < filtered.length;
    }),
    hasPreviousPage: computed(() => state.page() > 1),

    // Loading state computed
    isIdle: computed(() => !state.isLoading() && !state.isRefreshing()),
    hasError: computed(() => state.error() !== null),

    // Selection helpers
    isPositionSelected: computed(() => state.selectedPosition() !== null),
    selectedPositionId: computed(() => state.selectedPosition()?.id ?? null),

    // Formatted values
    formattedTotalPnL: computed(() => {
      const pnl = state.positions().reduce((sum, p) => sum + p.unrealizedPnL, 0);
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
      }).format(pnl);
    }),
  })),

  withMethods((store, tradingService = inject(TradingService)) => ({
    // Synchronous state updates
    setLoading(isLoading: boolean): void {
      patchState(store, { isLoading });
    },

    setError(error: string | null): void {
      patchState(store, { error });
    },

    selectPosition(position: Position | null): void {
      patchState(store, { selectedPosition: position });
    },

    selectPositionById(id: string): void {
      const position = store.positions().find((p) => p.id === id) ?? null;
      patchState(store, { selectedPosition: position });
    },

    clearSelection(): void {
      patchState(store, { selectedPosition: null });
    },

    setFilters(filters: Partial<PortfolioFilters>): void {
      patchState(store, {
        filters: { ...store.filters(), ...filters },
        page: 1, // Reset to first page when filters change
      });
    },

    clearFilters(): void {
      patchState(store, {
        filters: initialState.filters,
        page: 1,
      });
    },

    setSort(field: string, direction: 'asc' | 'desc'): void {
      patchState(store, { sortField: field, sortDirection: direction });
    },

    setPage(page: number): void {
      patchState(store, { page });
    },

    setPageSize(pageSize: number): void {
      patchState(store, { pageSize, page: 1 });
    },

    nextPage(): void {
      if (store.hasNextPage()) {
        patchState(store, { page: store.page() + 1 });
      }
    },

    previousPage(): void {
      if (store.hasPreviousPage()) {
        patchState(store, { page: store.page() - 1 });
      }
    },

    // Optimistic updates
    addPosition(position: Position): void {
      patchState(store, {
        positions: [...store.positions(), position],
        totalItems: store.totalItems() + 1,
      });
    },

    updatePosition(position: Position): void {
      patchState(store, {
        positions: store.positions().map((p) => (p.id === position.id ? position : p)),
      });
    },

    removePosition(id: string): void {
      patchState(store, {
        positions: store.positions().filter((p) => p.id !== id),
        totalItems: store.totalItems() - 1,
        selectedPosition: store.selectedPosition()?.id === id ? null : store.selectedPosition(),
      });
    },

    // Async methods with rxMethod
    loadPositions: rxMethod<void>(
      pipe(
        tap(() => patchState(store, { isLoading: true, error: null })),
        switchMap(() =>
          tradingService.getPositions().pipe(
            tapResponse({
              next: (positions) =>
                patchState(store, {
                  positions,
                  totalItems: positions.length,
                  isLoading: false,
                  lastUpdated: new Date(),
                }),
              error: (error: Error) =>
                patchState(store, {
                  error: error.message,
                  isLoading: false,
                }),
            }),
          ),
        ),
      ),
    ),

    refreshPositions: rxMethod<void>(
      pipe(
        tap(() => patchState(store, { isRefreshing: true })),
        switchMap(() =>
          tradingService.getPositions().pipe(
            tapResponse({
              next: (positions) =>
                patchState(store, {
                  positions,
                  totalItems: positions.length,
                  isRefreshing: false,
                  lastUpdated: new Date(),
                }),
              error: () => patchState(store, { isRefreshing: false }),
            }),
          ),
        ),
      ),
    ),

    loadPositionById: rxMethod<string>(
      pipe(
        tap(() => patchState(store, { isLoading: true })),
        switchMap((id) =>
          tradingService.getPositionById(id).pipe(
            tapResponse({
              next: (position) =>
                patchState(store, {
                  selectedPosition: position,
                  isLoading: false,
                }),
              error: (error: Error) =>
                patchState(store, {
                  error: error.message,
                  isLoading: false,
                }),
            }),
          ),
        ),
      ),
    ),

    closePosition: rxMethod<string>(
      pipe(
        switchMap((id) =>
          tradingService.closePosition(id).pipe(
            tapResponse({
              next: () => {
                patchState(store, {
                  positions: store.positions().filter((p) => p.id !== id),
                  selectedPosition:
                    store.selectedPosition()?.id === id ? null : store.selectedPosition(),
                });
              },
              error: (error: Error) =>
                patchState(store, {
                  error: error.message,
                }),
            }),
          ),
        ),
      ),
    ),

    searchPositions: rxMethod<string>(
      pipe(
        debounceTime(300),
        distinctUntilChanged(),
        switchMap((query) =>
          tradingService.searchPositions(query).pipe(
            tapResponse({
              next: (positions) =>
                patchState(store, {
                  positions,
                  totalItems: positions.length,
                  page: 1,
                }),
              error: () => {},
            }),
          ),
        ),
      ),
    ),
  })),

  withHooks({
    onInit(store) {
      console.log('PortfolioStore initialized');
      store.loadPositions();
    },
    onDestroy() {
      console.log('PortfolioStore destroyed');
    },
  }),
);

