    def _parse_proto(self, file_path: Path, matrix: ProjectMatrix):
        """Parse Protocol Buffer file"""
        try:
            content = file_path.read_text()
            import re

            # Find service definitions
            service_pattern = r'service\s+(\w+)\s*\{([^}]+)\}'
            service_matches = re.findall(service_pattern, content, re.DOTALL)

            for service_name, service_body in service_matches:
                # Find RPC methods
                methods = []
                rpc_pattern = r'rpc\s+(\w+)\s*\('
                rpc_matches = re.findall(rpc_pattern, service_body)
                methods.extend(rpc_matches)

                # Find port from comments
                port_pattern = r'Port:\s*(\d+)'
                port_match = re.search(port_pattern, content)
                port = port_match.group(1) if port_match else None

                matrix.grpc_services.append({
                    "name": service_name,
                    "file": str(file_path),
                    "port": port,
                    "methods": methods,
                })

        except Exception as e:
            print(f"[CodeTrellis] Warning: Could not parse proto {file_path}: {e}")

    def _parse_python(self, file_path: Path, matrix: ProjectMatrix):
        """
        Parse Python file using EnhancedPythonParser.
        v4.0: Full Python language support with ML/AI, frameworks, databases.
        """
        try:
            content = file_path.read_text()
            if not content.strip():
                return

            # Parse with enhanced Python parser
            result = self.python_parser.parse(content, str(file_path))

            # Core Python Types
            if result.dataclasses:
                for dc in result.dataclasses:
                    options = getattr(dc, 'options', {}) or {}
                    matrix.python_dataclasses.append({
                        "name": dc.name,
                        "file": str(file_path),
                        "fields": [{"name": f.name, "type": f.type, "default": f.default} for f in dc.fields],
                        "is_frozen": options.get('frozen', False),
                    })

            if result.pydantic_models:
                for model in result.pydantic_models:
                    # Convert validators to string names
                    validator_names = [v.name for v in model.validators] if model.validators else []
                    matrix.python_pydantic_models.append({
                        "name": model.name,
                        "file": str(file_path),
                        "fields": [{"name": f.name, "type": f.type, "required": f.required} for f in model.fields],
                        "validators": validator_names,
                    })

            if result.typeddicts:
                for td in result.typeddicts:
                    # TypedDictInfo uses 'keys' attribute, not 'fields'
