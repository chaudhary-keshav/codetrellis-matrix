  readonly sortedPositions = computed(() => {
    const positions = [...this.filteredPositions()];
    const field = this.sortField();
    const direction = this.sortDirection();

    return positions.sort((a, b) => {
      const aVal = a[field as keyof Position];
      const bVal = b[field as keyof Position];
      const comparison = aVal < bVal ? -1 : aVal > bVal ? 1 : 0;
      return direction === 'asc' ? comparison : -comparison;
    });
  });

  readonly paginatedPositions = computed(() => {
    const start = this.pageIndex() * this.pageSize();
    return this.sortedPositions().slice(start, start + this.pageSize());
  });

  readonly totalPages = computed(() =>
    Math.ceil(this.filteredPositions().length / this.pageSize()),
  );

  // Aggregated metrics
  readonly metrics = computed<DashboardMetrics>(() => ({
    totalPositions: this.positionCount(),
    totalPnL: this.totalPnL(),
    totalValue: this.totalValue(),
    openOrdersCount: this.openOrders().length,
    winRate: this.calculateWinRate(this.positions()),
    sharpeRatio: this.calculateSharpeRatio(this.positions()),
  }));

  // UI state computed
  readonly isFormValid = computed(() => this.orderForm.valid);
  readonly canSubmitOrder = computed(() => this.isFormValid() && !this.isSubmitting());
  readonly showLoadingOverlay = computed(() => this.isLoading() || this.isRefreshing());
  readonly tableClasses = computed(() => ({
    'dark-theme': this.theme() === 'dark',
    'light-theme': this.theme() === 'light',
    loading: this.isLoading(),
  }));

  // === PRIVATE FIELDS ===
  private readonly destroy$ = new Subject<void>();
  private readonly searchSubject$ = new BehaviorSubject<string>('');
  private dataSource = new MatTableDataSource<Position>();

  // === LIFECYCLE HOOKS ===
  ngOnInit(): void {
    this.setupWebSocketConnection();
    this.setupSearchSubscription();
    this.loadInitialData();
    this.setupAutoRefresh();
  }

  ngOnDestroy(): void {
    this.destroy$.next();
    this.destroy$.complete();
    this.wsService.disconnect();
  }

  // === PUBLIC METHODS ===
  async placeOrder(orderData: CreateOrderRequest): Promise<void> {
    this.isSubmitting.set(true);
    this.errorMessage.set(null);

    try {
      const order = await this.tradingService.placeOrder(orderData);
      this.orderPlaced.emit(order);
      this.notificationService.success(`Order placed: ${order.id}`);
      this.orderForm.reset();
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Failed to place order';
      this.errorMessage.set(message);
      this.error.emit({ type: 'ORDER_FAILED', message, timestamp: new Date() });
    } finally {
      this.isSubmitting.set(false);
    }
  }

  async cancelOrder(orderId: string, reason: string = 'User cancelled'): Promise<void> {
    try {
      await this.tradingService.cancelOrder(orderId);
      this.orderCancelled.emit({ orderId, reason });
      this.notificationService.success('Order cancelled');
    } catch (error) {
      this.notificationService.error('Failed to cancel order');
    }
  }

  async closePosition(position: Position): Promise<void> {
    try {
      const result = await this.tradingService.closePosition(position.id);
      this.positionClosed.emit({
        positionId: position.id,
        symbol: position.symbol,
        realizedPnL: result.realizedPnL,
        closedAt: new Date(),
      });
    } catch (error) {
      this.notificationService.error('Failed to close position');
    }
  }

  refreshData(): void {
    this.isRefreshing.set(true);
    this.portfolioStore
      .loadPositions()
      .then(() => this.isRefreshing.set(false))
      .catch(() => {
        this.errorMessage.set('Failed to refresh');
        this.isRefreshing.set(false);
      });
  }

  setActiveTab(tab: 'positions' | 'orders' | 'trades' | 'chart'): void {
    this.activeTab.set(tab);
    this.tabChanged.emit(tab);
  }

  togglePosition(position: Position): void {
    const current = this.selectedPositions();
    const index = current.findIndex((p) => p.id === position.id);

    if (index >= 0) {
      this.selectedPositions.set([...current.slice(0, index), ...current.slice(index + 1)]);
    } else {
      this.selectedPositions.set([...current, position]);
    }

    this.selectionChanged.emit(this.selectedPositions());
  }

  selectAll(): void {
    this.selectedPositions.set([...this.filteredPositions()]);
    this.selectionChanged.emit(this.selectedPositions());
  }

  clearSelection(): void {
    this.selectedPositions.set([]);
    this.selectionChanged.emit([]);
  }

  onPageChange(event: PageEvent): void {
    this.pageIndex.set(event.pageIndex);
    this.pageSize.set(event.pageSize);
  }

  onSortChange(sort: Sort): void {
    this.sortField.set(sort.active);
    this.sortDirection.set(sort.direction as 'asc' | 'desc');
  }

  applyFilters(filters: DashboardFilters): void {
    // Apply filters logic
    this.filtersChanged.emit(filters);
  }

  async exportData(format: 'csv' | 'xlsx' | 'json'): Promise<void> {
    const data = this.filteredPositions();
    const result = await this.tradingService.exportPositions(data, format);
    this.exported.emit({ format, rowCount: data.length, success: true });
  }

  // Form helpers
  updateOrderType(type: OrderType): void {
    this.orderForm.patchValue({ orderType: type });

    // Clear/enable price fields based on order type
    if (type === 'MARKET') {
      this.orderForm.get('limitPrice')?.disable();
      this.orderForm.get('stopPrice')?.disable();
    } else if (type === 'LIMIT') {
      this.orderForm.get('limitPrice')?.enable();
      this.orderForm.get('stopPrice')?.disable();
    } else if (type === 'STOP_LIMIT') {
      this.orderForm.get('limitPrice')?.enable();
      this.orderForm.get('stopPrice')?.enable();
    }
  }

  // === PRIVATE METHODS ===
  private setupWebSocketConnection(): void {
    this.wsService.connect(this.accountId());

    this.wsService.onMessage$
      .pipe(takeUntil(this.destroy$))
      .subscribe((message) => this.handleWebSocketMessage(message));

    this.wsService.connectionStatus$
      .pipe(takeUntil(this.destroy$))
      .subscribe((status) => this.connectionStatus.set(status));
  }

  private setupSearchSubscription(): void {
    this.searchSubject$
      .pipe(debounceTime(300), distinctUntilChanged(), takeUntil(this.destroy$))
      .subscribe();
  }

  private loadInitialData(): void {
    this.isLoading.set(true);

    combineLatest([
      this.portfolioStore.loadPositions(),
      this.ordersStore.loadOrders(),
      this.marketDataStore.loadMarketData(),
    ])
      .pipe(
        takeUntil(this.destroy$),
        catchError((error) => {
          this.errorMessage.set('Failed to load data');
          return of([]);
        }),
      )
      .subscribe({
        next: () => this.isLoading.set(false),
        error: () => this.isLoading.set(false),
      });
  }

  private setupAutoRefresh(): void {
    // Auto-refresh based on refreshInterval input
  }

  private handleWebSocketMessage(message: WebSocketMessage): void {
    switch (message.type) {
      case 'PRICE_UPDATE':
        this.currentPrice.set(message.payload.price);
        break;
      case 'ORDER_UPDATE':
        this.ordersStore.updateOrder(message.payload);
        break;
      case 'POSITION_UPDATE':
        this.portfolioStore.updatePosition(message.payload);
        break;
    }
    this.lastUpdate.set(new Date());
  }

  private calculateWinRate(positions: Position[]): number {
    if (positions.length === 0) return 0;
    const winners = positions.filter((p) => p.unrealizedPnL > 0).length;
    return (winners / positions.length) * 100;
  }

  private calculateSharpeRatio(positions: Position[]): number {
    // Simplified Sharpe ratio calculation
    return 1.5;
  }
}

// === LOCAL INTERFACES ===
interface DashboardFilters {
  symbols: string[];
  orderTypes: OrderType[];
  minPnL: number | null;
  maxPnL?: number | null;
  dateRange?: { start: Date; end: Date };
}

interface DashboardConfig {
  autoRefresh: boolean;
  refreshInterval: number;
  defaultTab: 'positions' | 'orders' | 'trades' | 'chart';
  columns: ColumnConfig[];
  theme: 'light' | 'dark';
}

interface ColumnConfig {
  field: string;
  header: string;
  visible: boolean;
  width?: number;
  sortable?: boolean;
  filterable?: boolean;
}

interface DashboardMetrics {
  totalPositions: number;
  totalPnL: number;
  totalValue: number;
  openOrdersCount: number;
  winRate: number;
  sharpeRatio: number;
}

interface PositionCloseEvent {
  positionId: string;
  symbol: string;
  realizedPnL: number;
  closedAt: Date;
}

interface ErrorEvent {
  type: string;
  message: string;
  timestamp: Date;
  details?: unknown;
}

interface ExportResult {
  format: 'csv' | 'xlsx' | 'json';
  rowCount: number;
  success: boolean;
  error?: string;
}

interface CreateOrderRequest {
  symbol: string;
  quantity: number;
  side: OrderSide;
  orderType: OrderType;
  limitPrice?: number;
  stopPrice?: number;
  timeInForce: TimeInForce;
}

interface WebSocketMessage {
  type: 'PRICE_UPDATE' | 'ORDER_UPDATE' | 'POSITION_UPDATE' | 'TRADE_EXECUTED' | 'ERROR';
  payload: unknown;
  timestamp: string;
}

// === LOCAL TYPE ALIASES ===
type ChartType = 'candlestick' | 'line' | 'bar' | 'area';
type Timeframe = '1m' | '5m' | '15m' | '1H' | '4H' | '1D' | '1W' | '1M';
type TimeInForce = 'DAY' | 'GTC' | 'IOC' | 'FOK';
type ConnectionStatus = 'connected' | 'disconnected' | 'reconnecting' | 'error';
type SortDirection = 'asc' | 'desc' | '';
