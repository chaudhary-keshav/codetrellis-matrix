    def _compress_python_data(self, matrix) -> List[str]:
        """Compress Python data operations (Pandas, Pipelines)"""
        lines = []

        # Pandas Operations (summarize, don't list all)
        if hasattr(matrix, 'python_pandas_operations') and matrix.python_pandas_operations:
            ops_by_type = {}
            for op in matrix.python_pandas_operations:
                op_type = op.get('type', 'unknown')
                ops_by_type[op_type] = ops_by_type.get(op_type, 0) + 1
            if ops_by_type:
                lines.append("# Pandas Operations")
                op_summary = ','.join(f"{k}:{v}" for k, v in ops_by_type.items())
                lines.append(f"  operations:{op_summary}")

        # Pipeline DAGs
        if hasattr(matrix, 'python_pipeline_dags') and matrix.python_pipeline_dags:
            lines.append("# Data Pipelines")
            for dag in matrix.python_pipeline_dags:
                framework = dag.get('framework', '')
                tasks = dag.get('tasks', [])
                task_names = [t.get('name', t) if isinstance(t, dict) else str(t) for t in tasks]
                lines.append(f"  {dag['name']}|{framework}|tasks:{','.join(task_names[:5])}")

        # MLflow Experiments
        if hasattr(matrix, 'python_mlflow_experiments') and matrix.python_mlflow_experiments:
            lines.append("# MLflow")
            for exp in matrix.python_mlflow_experiments:
                uri = exp.get('tracking_uri', '')
                uri_str = f"|uri:{uri}" if uri else ""
