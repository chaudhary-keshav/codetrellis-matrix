### 1.3 Smart Model Selector (Mode 4 Deep Dive)

This is your innovative idea - using a small, specialized model to intelligently select practices:

```python
"""
Smart Practice Selector using Small Language Model

This approach trains a small model (~100M parameters) to:
1. Analyze CodeTrellis matrix output
2. Understand user intent/query
3. Select optimal practices from BPL
4. Compress and format for target LLM
"""

from dataclasses import dataclass
from typing import List, Tuple
import json


@dataclass
class SelectionInput:
    """Input to the smart selector model"""
    codetrellis_matrix: str              # Compressed CodeTrellis output
    user_query: str               # What the user wants to do
    target_token_budget: int      # How many tokens available
    project_scale: str            # enterprise, startup, etc.


@dataclass
class SelectionOutput:
    """Output from the smart selector model"""
    selected_practice_ids: List[str]
    reasoning: str                # Why these were selected
    confidence: float
    compressed_output: str


class SmartPracticeSelector:
    """
    Uses a fine-tuned small model to select practices.

    Training Data Format:
    {
        "input": "<codetrellis_matrix> <query> <budget>",
        "output": {
            "practices": ["python.naming", "solid.srp", "pattern.factory"],
            "reasoning": "User is creating a new service class..."
        }
    }
    """

    def __init__(self, model_path: str):
        # Load fine-tuned model (e.g., Phi-2, Gemma 2B, or custom)
        self.model = self._load_model(model_path)
        self.repository = BestPracticesRepository()

    def select(self, input: SelectionInput) -> SelectionOutput:
        """Run inference to select practices"""

        # Format prompt for the small model
        prompt = self._format_selector_prompt(input)

        # Get model prediction
        response = self.model.generate(prompt)

        # Parse and validate
        selected = self._parse_response(response)

        # Fetch full practices and compress
        practices = [self.repository.get(id) for id in selected.practice_ids]
        compressed = self._compress_to_budget(practices, input.target_token_budget)

        return SelectionOutput(
            selected_practice_ids=selected.practice_ids,
            reasoning=selected.reasoning,
            confidence=selected.confidence,
            compressed_output=compressed
        )

    def _format_selector_prompt(self, input: SelectionInput) -> str:
        """Format prompt for the selector model"""
        return f"""<|system|>
You are a software engineering expert. Given a project analysis and user query,
select the most relevant best practices from our library.

Available practice categories: language, framework, pattern, principle, security, testing

<|user|>
PROJECT ANALYSIS:
{input.codetrellis_matrix[:2000]}  # Truncate for small model context

USER QUERY:
{input.user_query}

CONSTRAINTS:
- Token budget: {input.target_token_budget}
- Project scale: {input.project_scale}

Select 5-15 most relevant practices and explain why.

<|assistant|>"""

    def create_training_data(
        self,
        examples: List[Tuple[SelectionInput, SelectionOutput]]
    ) -> str:
        """Generate training data for fine-tuning the selector"""
        training_data = []

        for input, output in examples:
            training_data.append({
                "messages": [
                    {"role": "system", "content": "Select relevant best practices"},
                    {"role": "user", "content": self._format_input(input)},
                    {"role": "assistant", "content": json.dumps({
                        "practices": output.selected_practice_ids,
                        "reasoning": output.reasoning
                    })}
                ]
            })

        return "\n".join(json.dumps(d) for d in training_data)
```

