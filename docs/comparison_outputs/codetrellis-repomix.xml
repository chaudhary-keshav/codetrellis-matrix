interface Position {
  id: string;
  symbol: string;
  quantity: number;
  averagePrice: number;
  currentPrice: number;
  marketValue: number;
  costBasis: number;
  unrealizedPnL: number;
  unrealizedPnLPercent: number;
  side: 'LONG' | 'SHORT';
  openedAt: Date;
  lastUpdated: Date;
}

interface PortfolioFilters {
  symbols: string[];
  minPnL: number | null;
  maxPnL: number | null;
  status: 'all' | 'winning' | 'losing';
  dateRange?: {
    start: Date;
    end: Date;
  };
}

// Export types for consumers
export type { PortfolioFilters, PortfolioState, Position };
