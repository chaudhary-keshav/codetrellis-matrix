  readonly displayName = computed(() => `Account: ${this.accountId()}`);
  readonly positionCount = computed(() => this.positions().length);
  readonly hasPositions = computed(() => this.positionCount() > 0);
  readonly hasOpenOrders = computed(() => this.openOrders().length > 0);

