    def _detect_stack(self, matrix) -> List[str]:
        """Detect technology stack from dependencies"""
        stack = []
        deps = matrix.dependencies

        if "@nestjs/common" in deps:
            version = deps["@nestjs/common"].replace("^", "").replace("~", "")
            stack.append(f"nestjs:{version}")

        if "@angular/core" in deps:
            version = deps["@angular/core"].replace("^", "").replace("~", "")
            stack.append(f"angular:{version}")

        # Check for common databases
        if any("mongoose" in d for d in deps):
            stack.append("mongodb")
        if any("redis" in d.lower() for d in deps):
            stack.append("redis")

        return stack

    def _compress_service(self, name: str, info: Dict) -> str:
        """Compress service info to single line"""
        parts = [name]

        if info.get('port'):
            if info.get('grpc_port'):
                parts.append(f"port:{info['port']}/{info['grpc_port']}")
            else:
                parts.append(f"port:{info['port']}")

        if info.get('modules'):
            parts.append(f"modules:{','.join(info['modules'])}")

        return '|'.join(parts)

    def _compress_schema(self, schema: Dict) -> str:
        """Compress schema to single line"""
        name = schema['name']

        # Skip empty schemas or Document types
        fields = schema.get('fields', [])
        if not fields:
            return f"{name}|empty|ts"

        # Compress fields - limit to essential ones for brevity
        field_parts = []
        seen_types = set()  # Avoid duplicate type references

        for field in fields:
            field_str = field['name']

            if field.get('required'):
                field_str += '!'
            if field.get('unique'):
                field_str += 'u'

            # Handle array types
            field_type = field.get('type', '')
            if '[]' in field_type or 'Array' in field_type:
                # Extract inner type
                inner = field_type.replace('[]', '').replace('Array<', '').replace('>', '').strip()
                if inner and inner not in ['string', 'number', 'boolean']:
                    field_str += f'[{inner}]'
                else:
                    field_str += '[]'
            elif field_type not in ['string', 'number', 'boolean', 'Date']:
                # Custom type reference
                field_str += f'[{field_type}]'

            field_parts.append(field_str)

        fields_str = ','.join(field_parts) if field_parts else ''

        return f"{name}|fields:{fields_str}|ts"

    def _compress_dto(self, dto: Dict) -> str:
        """Compress DTO to single line"""
        name = dto['name']

        field_parts = []
        for field in dto.get('fields', []):
            field_str = field['name']

            # Add validators as decorators
            validators = field.get('validators', [])
            for v in validators[:2]:  # Limit to 2 validators
                field_str += f'@{v}'

            field_parts.append(field_str)

        fields_str = ','.join(field_parts)
        return f"{name}|{fields_str}"

    def _compress_controller(self, ctrl: Dict) -> str:
        """Compress controller to single line"""
        name = ctrl['name']
        prefix = ctrl.get('prefix', '/')

        # Group routes by method
        routes_by_method = {}
        for route in ctrl.get('routes', []):
            method = route['method']
            path = route['path']
            if method not in routes_by_method:
                routes_by_method[method] = []
            routes_by_method[method].append(path)

        # Format routes
        route_parts = []
        for method, paths in routes_by_method.items():
            route_parts.append(f"{method}:{','.join(paths)}")

        routes_str = ';'.join(route_parts)
        return f"{name}|prefix:{prefix}|routes:{routes_str}"

    def _compress_component(self, comp: Dict) -> str:
        """Compress Angular component to single line"""
        name = comp['name']

        parts = [name]

        if comp.get('inputs'):
            parts.append(f"@in:{','.join(comp['inputs'])}")
        if comp.get('outputs'):
            parts.append(f"@out:{','.join(comp['outputs'])}")

        return '|'.join(parts)

    def _compress_interface(self, iface: Dict) -> str:
        """Compress TypeScript interface to single line (v2.0)"""
        name = iface['name']
        parts = []

        # Add export marker
        if iface.get('exported'):
            parts.append('export')

        parts.append(f"interface {name}")

        # Add generics
        if iface.get('generics'):
            parts[-1] += f"<{','.join(iface['generics'])}>"

        # Add extends
        if iface.get('extends'):
            parts[-1] += f" extends {','.join(iface['extends'])}"

        # Compress properties based on tier
        props = iface.get('properties', [])
        if props:
            prop_strs = []

            # Determine limit based on tier
            if self.tier == OutputTier.COMPACT:
                limit = self.COMPACT_LIMITS['properties']
                type_max_len = 20
            else:
                # PROMPT and FULL: no limit
                limit = len(props)
                type_max_len = 100 if self.tier == OutputTier.FULL else 50

            for p in props[:limit]:
                opt = '?' if p.get('optional') else ''
                ro = 'readonly ' if p.get('readonly') else ''
                # Truncate long types only in COMPACT mode
                ptype = p.get('type', 'any')
                if len(ptype) > type_max_len:
                    ptype = ptype[:type_max_len-3] + '...'
                prop_strs.append(f"{ro}{p['name']}{opt}:{ptype}")

            props_str = ','.join(prop_strs)
            # Only add "+Nmore" in COMPACT tier
            if self.tier == OutputTier.COMPACT and len(props) > limit:
                props_str += f",+{len(props)-limit}more"
            parts.append(f"props:[{props_str}]")

        # Add methods based on tier
        methods = iface.get('methods', [])
        if methods:
            if self.tier == OutputTier.COMPACT:
                parts.append(f"methods:{len(methods)}")
            else:
                # PROMPT/FULL: show all method signatures
                method_strs = []
                for m in methods:
                    params = m.get('params', '')
                    ret = m.get('return_type', 'void')
                    method_strs.append(f"{m['name']}({params}):{ret}")
                parts.append(f"methods:[{','.join(method_strs)}]")

        return '|'.join(parts)

    def _compress_type(self, t: Dict) -> str:
        """Compress TypeScript type alias to single line (v2.0)"""
        name = t['name']
        parts = []

        # Add export marker
        if t.get('exported'):
            parts.append('export')

        parts.append(f"type {name}")

        # Add generics
        if t.get('generics'):
            parts[-1] += f"<{','.join(t['generics'])}>"

        # Add kind
        kind = t.get('kind', 'simple')
        parts.append(f"kind:{kind}")

        # Compress type definition (truncate if long)
        type_def = t.get('type', '')
        if len(type_def) > 50:
            type_def = type_def[:47] + '...'
        parts.append(f"def:{type_def}")

        return '|'.join(parts)

    def _compress_angular_service(self, service: Dict) -> str:
        """Compress Angular service to single line (v2.0)"""
        name = service['name']
        parts = [f"@Injectable class {name}"]

        # Provided in
        provided_in = service.get('provided_in', 'root')
        if provided_in != 'root':
            parts.append(f"providedIn:{provided_in}")

        # Determine limits based on tier
        if self.tier == OutputTier.COMPACT:
            deps_limit = self.COMPACT_LIMITS['dependencies']
            signals_limit = self.COMPACT_LIMITS['signals']
            methods_limit = self.COMPACT_LIMITS['methods']
        else:
            deps_limit = signals_limit = methods_limit = 999999  # No limit

        # Dependencies
        deps = service.get('dependencies', [])
        if deps:
            deps_str = ','.join([d['type'] for d in deps[:deps_limit]])
            if self.tier == OutputTier.COMPACT and len(deps) > deps_limit:
                deps_str += f",+{len(deps)-deps_limit}more"
            parts.append(f"inject:[{deps_str}]")

        # Signals
        signals = service.get('signals', [])
        if signals:
            signals_str = ','.join([f"{s['name']}:{s['signal_type']}" for s in signals[:signals_limit]])
            if self.tier == OutputTier.COMPACT and len(signals) > signals_limit:
                signals_str += f",+{len(signals)-signals_limit}more"
            parts.append(f"signals:[{signals_str}]")

        # Methods
        methods = service.get('methods', [])
        if methods:
            if self.tier == OutputTier.FULL:
                # Full tier: show method signatures
                method_parts = []
                for m in methods:
                    if isinstance(m, dict):
                        method_parts.append(f"{m.get('name', m)}({m.get('params', '')})")
                    else:
                        method_parts.append(str(m))
                methods_str = ','.join(method_parts)
            else:
                methods_str = ','.join(str(m) for m in methods[:methods_limit])
                if self.tier == OutputTier.COMPACT and len(methods) > methods_limit:
                    methods_str += f",+{len(methods)-methods_limit}more"
            parts.append(f"methods:[{methods_str}]")

        return '|'.join(parts)

    def _compress_store(self, store: Dict) -> str:
        """Compress NgRx SignalStore to single line (v2.0)"""
        name = store['name']
        parts = [f"signalStore {name}"]

        # Features
        features = store.get('features', [])
        if features:
            parts.append(f"features:[{','.join(features)}]")

        # Determine limits based on tier
        if self.tier == OutputTier.COMPACT:
            state_limit = self.COMPACT_LIMITS['state']
            computed_limit = self.COMPACT_LIMITS['computed']
            methods_limit = self.COMPACT_LIMITS['methods']
        else:
            state_limit = computed_limit = methods_limit = 999999  # No limit

        # State properties
        state_props = store.get('state_properties', [])
        if state_props:
            if self.tier == OutputTier.FULL:
                # Full: show with types
                props_str = ','.join([f"{p['name']}:{p.get('type', 'unknown')}" for p in state_props[:state_limit]])
            else:
                props_str = ','.join([p['name'] for p in state_props[:state_limit]])
            if self.tier == OutputTier.COMPACT and len(state_props) > state_limit:
                props_str += f",+{len(state_props)-state_limit}more"
            parts.append(f"state:[{props_str}]")

        # Computed
        computed = store.get('computed', [])
        if computed:
            computed_str = ','.join(str(c) for c in computed[:computed_limit])
            if self.tier == OutputTier.COMPACT and len(computed) > computed_limit:
                computed_str += f",+{len(computed)-computed_limit}more"
            parts.append(f"computed:[{computed_str}]")

        # Methods
        methods = store.get('methods', [])
        if methods:
            methods_str = ','.join(str(m) for m in methods[:methods_limit])
            if self.tier == OutputTier.COMPACT and len(methods) > methods_limit:
                methods_str += f",+{len(methods)-methods_limit}more"
            parts.append(f"methods:[{methods_str}]")

        return '|'.join(parts)

    def _compress_routes(self, routes_file: Dict) -> List[str]:
        """Compress Angular routes to multiple lines (v2.0)"""
        lines = []

        # Header line with stats
        file_name = routes_file.get('file', '').split('/')[-1]
        total = routes_file.get('total_routes', 0)
        lazy = routes_file.get('lazy_routes', 0)
        guarded = routes_file.get('guarded_routes', 0)

        lines.append(f"# {file_name} ({total} routes, {lazy} lazy, {guarded} guarded)")

        # Compress each route
        routes = routes_file.get('routes', [])
        for route in routes:
            route_line = self._compress_single_route(route, prefix='')
            lines.append(route_line)

            # Add children with indentation
            children = route.get('children', [])
            for child in children:
                child_line = self._compress_single_route(child, prefix='  └─')
                lines.append(child_line)

        return lines

    def _compress_single_route(self, route: Dict, prefix: str = '') -> str:
        """Compress a single route to a line"""
        parts = []

        path = route.get('path', '')
        parts.append(f"'{path}'")

        # Component
        if route.get('component'):
            parts.append(f"→ {route['component']}")

        # Redirect
        if route.get('redirectTo'):
            parts.append(f"↪ '{route['redirectTo']}'")

        # Lazy loading
        if route.get('lazyLoad'):
            lazy = route['lazyLoad']
            parts.append(f"lazy({lazy.get('type', '?')})")

        # Route params
        if route.get('params'):
            parts.append(f"params:[{','.join(route['params'])}]")

        # Guards
        if route.get('guards'):
            for guard in route['guards']:
                guard_names = ','.join(guard.get('guards', []))
                parts.append(f"{guard['type']}:[{guard_names}]")

        # Children count (if any)
        children = route.get('children', [])
        if children:
            parts.append(f"children:{len(children)}")

        return f"{prefix}{' | '.join(parts)}"

    def _compress_websocket_events(self, ws_file: Dict) -> List[str]:
        """Compress WebSocket events to multiple lines (v2.0)"""
        lines = []

        # Extract file name
        file_path = ws_file.get('filePath', '')
        file_name = file_path.split('/')[-1] if file_path else 'unknown'

        stats = ws_file.get('stats', {})
        total = stats.get('totalEvents', 0)
        incoming = stats.get('incomingEvents', 0)
        outgoing = stats.get('outgoingEvents', 0)

        lines.append(f"# {file_name} ({total} events: {incoming} in, {outgoing} out)")

        # Determine limits based on tier
        if self.tier == OutputTier.COMPACT:
            on_limit = self.COMPACT_LIMITS['events']
            emit_limit = 5
        else:
            on_limit = emit_limit = 999999  # No limit

        # Process each connection
        connections = ws_file.get('connections', [])
        for conn in connections:
            socket_name = conn.get('socketName', 'socket')
            url = conn.get('url') or conn.get('urlVariable', '')

            lines.append(f"  {socket_name} → {url}")

            # Group events by type
            events = conn.get('events', [])
            on_events = [e for e in events if e.get('type') == 'on']
            emit_events = [e for e in events if e.get('type') == 'emit']

            # Show incoming events
            if on_events:
                if self.tier == OutputTier.FULL:
                    # Full: show with payload types
                    event_strs = [f"{e.get('eventName', '')}:{e.get('payloadType', 'any')}" for e in on_events[:on_limit]]
                else:
                    event_strs = [e.get('eventName', '') for e in on_events[:on_limit]]
                lines.append(f"    ← on: [{', '.join(event_strs)}]")
                if self.tier == OutputTier.COMPACT and len(on_events) > on_limit:
                    lines.append(f"       +{len(on_events) - on_limit} more incoming events")

            # Show outgoing events
            if emit_events:
                if self.tier == OutputTier.FULL:
                    event_strs = [f"{e.get('eventName', '')}:{e.get('payloadType', 'any')}" for e in emit_events[:emit_limit]]
                else:
                    event_strs = [e.get('eventName', '') for e in emit_events[:emit_limit]]
                lines.append(f"    → emit: [{', '.join(event_strs)}]")
                if self.tier == OutputTier.COMPACT and len(emit_events) > emit_limit:
                    lines.append(f"       +{len(emit_events) - emit_limit} more outgoing events")

        return lines

    def _compress_http_api(self, api_file: Dict) -> List[str]:
        """Compress HTTP API endpoints to multiple lines (v2.0)"""
        lines = []

        # Extract file name
        file_path = api_file.get('filePath', '')
        file_name = file_path.split('/')[-1] if file_path else 'unknown'

        stats = api_file.get('stats', {})
        total = stats.get('total', 0)

        # Base URL if detected
        base_url = api_file.get('baseUrl', '')
        base_var = api_file.get('baseUrlVariable', '')

        if base_var and base_url:
            lines.append(f"# {file_name} ({total} endpoints) | base: {base_var}={base_url}")
        else:
            lines.append(f"# {file_name} ({total} endpoints)")

        # Determine limit based on tier
        if self.tier == OutputTier.COMPACT:
            endpoint_limit = self.COMPACT_LIMITS['endpoints']
            url_max_len = 50
        else:
            endpoint_limit = 999999  # No limit
            url_max_len = 200 if self.tier == OutputTier.FULL else 100

        # Group by HTTP method
        api_calls = api_file.get('apiCalls', [])

        # Show endpoints
        get_calls = [c for c in api_calls if c.get('method') == 'GET']
        post_calls = [c for c in api_calls if c.get('method') == 'POST']
        put_calls = [c for c in api_calls if c.get('method') == 'PUT']
        patch_calls = [c for c in api_calls if c.get('method') == 'PATCH']
        delete_calls = [c for c in api_calls if c.get('method') == 'DELETE']

        for method, calls in [('GET', get_calls), ('POST', post_calls),
                               ('PUT', put_calls), ('PATCH', patch_calls),
                               ('DELETE', delete_calls)]:
            if calls:
                urls = []
                for c in calls[:endpoint_limit]:
                    url = c.get('url', '')
                    # Simplify URL for display
                    if len(url) > url_max_len:
                        url = url[:url_max_len-3] + '...'
                    if self.tier == OutputTier.FULL:
                        # Full: show response type
                        resp_type = c.get('responseType', '')
                        if resp_type:
                            url = f"{url} → {resp_type}"
                    urls.append(url)
                lines.append(f"  {method}: {', '.join(urls)}")
                if self.tier == OutputTier.COMPACT and len(calls) > endpoint_limit:
                    lines.append(f"    +{len(calls) - endpoint_limit} more {method} endpoints")

        return lines

    def _compress_context(self, matrix) -> List[str]:
        """
        Phase 2: Compress context information (config, README, JSDoc)

        This section provides business context for AI understanding.
        """
        lines = []

        # Project configuration
        if hasattr(matrix, 'project_config') and matrix.project_config:
            config = matrix.project_config

            # Package info
            pkg = config.get('package')
            if pkg:
                parts = [f"{pkg.get('name', 'unknown')}@{pkg.get('version', '?')}"]
                if pkg.get('description'):
                    desc = pkg['description'][:100]
                    parts.append(f"desc:\"{desc}\"")
                lines.append(f"# Package: {' | '.join(parts)}")

            # Key dependencies
            if pkg and pkg.get('dependencyCount', 0) > 0:
                # Get key deps from the actual dependencies in matrix
                deps = matrix.dependencies
                key_deps = []
                for dep, ver in deps.items():
                    key_deps.append(f"{dep}:{ver}")
                if key_deps:
                    lines.append(f"# Key deps: {', '.join(key_deps[:8])}")

            # TypeScript config
            ts = config.get('tsconfig')
            if ts:
                ts_parts = []
                if ts.get('target'):
                    ts_parts.append(f"target:{ts['target']}")
                if ts.get('strictMode'):
                    ts_parts.append("strict")
                if ts.get('paths'):
                    ts_parts.append(f"paths:{len(ts['paths'])}")
                if ts_parts:
                    lines.append(f"# TypeScript: {', '.join(ts_parts)}")

            # Angular config
            ng = config.get('angular')
            if ng:
                lines.append(f"# Angular: prefix={ng.get('prefix', 'app')}, type={ng.get('projectType', '?')}")

            # Environment info
            envs = config.get('environments', [])
            if envs:
                env_summary = []
                for env in envs[:3]:
                    api_urls = env.get('apiUrls', {})
                    if api_urls:
                        for key, url in list(api_urls.items())[:2]:
                            env_summary.append(f"{key}={url}")
                if env_summary:
                    lines.append(f"# API Endpoints: {', '.join(env_summary)}")

        # README summary
        if hasattr(matrix, 'readme_info') and matrix.readme_info:
            readme = matrix.readme_info
            main = readme.get('mainReadme')
            if main:
                if main.get('title'):
                    lines.append(f"# README: {main['title']}")
                if main.get('description'):
                    desc = main['description'][:150] + "..." if len(main.get('description', '')) > 150 else main.get('description', '')
                    lines.append(f"# Description: {desc}")
                features = main.get('features', [])
                if features and self.tier != OutputTier.COMPACT:
                    lines.append(f"# Features: {', '.join(features[:5])}")

        # JSDoc documentation (only in PROMPT and FULL tiers)
        if self.tier in [OutputTier.PROMPT, OutputTier.FULL]:
            if hasattr(matrix, 'jsdoc_comments') and matrix.jsdoc_comments:
                documented_items = []
                for file_info in matrix.jsdoc_comments[:5]:
                    for comment in file_info.get('comments', []):
                        if comment.get('description'):
                            target = comment.get('target', 'unknown')
                            desc = comment['description'][:80]
                            documented_items.append(f"{target}:{desc}")

                if documented_items:
                    lines.append("# Documentation:")
                    for item in documented_items[:8]:
                        lines.append(f"#   {item}")

        return lines

    def _compress_error_handling(self, error_handling: List[Dict]) -> List[str]:
        """
        v3.0: Compress error handling patterns

        Output format:
            file.ts (3 try-catch, 2 http-handlers)
              try-catch: methodName→ErrorType
              catchError→handleError
        """
        lines = []

        # In COMPACT mode, just show summary
        if self.tier == OutputTier.COMPACT:
            total_files = len(error_handling)
            total_try_catch = sum(f.get('tryCatch', 0) for f in error_handling)
            total_http = sum(f.get('httpHandlers', 0) for f in error_handling)
            lines.append(f"# Summary: {total_files} files, {total_try_catch} try-catch, {total_http} http handlers")
            return lines

        for error_file in error_handling[:15]:  # Limit files
            file_path = error_file.get('file', 'unknown')
            file_name = file_path.split('/')[-1]

            try_catch = error_file.get('tryCatch', 0)
            http_handlers = error_file.get('httpHandlers', 0)
            error_classes = error_file.get('errorClasses', 0)
            boundaries = error_file.get('errorBoundaries', 0)

            # Summary line
            parts = []
            if try_catch:
                parts.append(f"{try_catch} try-catch")
            if http_handlers:
                parts.append(f"{http_handlers} http")
            if error_classes:
                parts.append(f"{error_classes} classes")
            if boundaries:
                parts.append(f"{boundaries} boundaries")

            lines.append(f"# {file_name} ({', '.join(parts)})")

            # In FULL mode, show details
            if self.tier == OutputTier.FULL and error_file.get('details'):
                detail_lines = error_file['details'].split('\n')[1:]  # Skip file header
                for line in detail_lines[:5]:  # Limit details
                    if line.strip():
                        lines.append(f"  {line.strip()}")

        return lines

    def _compress_todos(self, todos: List[Dict]) -> List[str]:
        """
        v3.0: Compress TODO/FIXME comments

        Output format:
            # Summary: 45 TODOs in 12 files (15 high priority)
            file.ts (8 todos, 2 high priority)
              TODO:line 42|implement caching
              FIXME:line 58|memory leak
        """
        lines = []

        # Calculate totals
        total_count = sum(f.get('count', 0) for f in todos)
        total_high = sum(f.get('highPriority', 0) for f in todos)
        total_files = len(todos)

        # Summary line
        lines.append(f"# Summary: {total_count} TODOs in {total_files} files ({total_high} high priority)")

        # In COMPACT mode, just show summary and top files
        if self.tier == OutputTier.COMPACT:
            if todos:
                top_files = sorted(todos, key=lambda x: x.get('highPriority', 0), reverse=True)[:5]
                for f in top_files:
                    file_path = f.get('file', 'unknown')
                    file_name = file_path.split('/')[-1]
                    lines.append(f"  {file_name}: {f.get('count', 0)} ({f.get('highPriority', 0)} high)")
            return lines

        # Type breakdown
        type_totals = {}
        for f in todos:
            for type_name, count in f.get('types', {}).items():
                type_totals[type_name] = type_totals.get(type_name, 0) + count

        if type_totals:
            type_str = ', '.join(f"{k}:{v}" for k, v in sorted(type_totals.items(), key=lambda x: -x[1]))
            lines.append(f"# By type: {type_str}")

        lines.append("")

        # File details (limited)
        for todo_file in todos[:10]:  # Limit files
            file_path = todo_file.get('file', 'unknown')
            file_name = file_path.split('/')[-1]
            count = todo_file.get('count', 0)
            high = todo_file.get('highPriority', 0)

            lines.append(f"# {file_name} ({count} todos, {high} high)")

            # In FULL mode, show individual items
            if self.tier == OutputTier.FULL and todo_file.get('items'):
                for item in todo_file['items'][:5]:  # Limit items per file
                    lines.append(f"  {item}")

        return lines

    def _compress_progress(self, progress) -> List[str]:
        """
        Compress project progress information.

        Format:
            completion:75%|todos:12|fixmes:3|deprecated:5
            priority:TODO!:file.ts:42:Implement auth,...
            blockers:BLOCKER:api.ts:10:Waiting for backend

        Args:
            progress: ProjectProgress object or dict

        Returns:
            List of compressed lines
        """
        lines = []

        # Handle both ProjectProgress object and dict
        if hasattr(progress, 'to_codetrellis_format'):
            # It's a ProjectProgress object
            codetrellis_output = progress.to_codetrellis_format()
            lines.extend(codetrellis_output.split('\n'))
        elif isinstance(progress, dict):
            # It's a dict from scanner
            completion = progress.get('completion', 100)
            summary = progress.get('summary', {})

            # Summary line
            summary_parts = [f"completion:{completion}%"]
            if summary.get('todos'):
                summary_parts.append(f"todos:{summary['todos']}")
            if summary.get('fixmes'):
                summary_parts.append(f"fixmes:{summary['fixmes']}")
            if summary.get('deprecated'):
                summary_parts.append(f"deprecated:{summary['deprecated']}")
            if summary.get('placeholders'):
                summary_parts.append(f"placeholders:{summary['placeholders']}")

            lines.append("|".join(summary_parts))

            # High priority items (COMPACT: limit to 3, PROMPT: limit to 5, FULL: all)
            high_priority = progress.get('high_priority', [])
            limit = 3 if self.tier == OutputTier.COMPACT else (5 if self.tier == OutputTier.PROMPT else len(high_priority))

            if high_priority[:limit]:
                priority_items = []
                for item in high_priority[:limit]:
                    marker_type = item.get('type', 'TODO').upper()
                    file_name = item.get('file', 'unknown').split('/')[-1]
                    line_num = item.get('line', 0)
                    msg = item.get('message', '')[:30]
                    priority_items.append(f"{marker_type}:{file_name}:{line_num}:{msg}")
                lines.append(f"priority:{','.join(priority_items)}")

            # Blockers
            blockers = progress.get('blockers', [])
            if blockers:
                blocker_items = []
                for item in blockers[:3]:
                    file_name = item.get('file', 'unknown').split('/')[-1]
                    msg = item.get('message', '')[:30]
                    blocker_items.append(f"{file_name}:{msg}")
                lines.append(f"blockers:{','.join(blocker_items)}")

            # In FULL mode, show per-file breakdown
            if self.tier == OutputTier.FULL and progress.get('files'):
                lines.append("# Per-file breakdown:")
                for file_prog in progress['files'][:10]:
                    file_name = file_prog.get('file', 'unknown').split('/')[-1]
                    status = file_prog.get('status', 'complete')
                    completion = file_prog.get('completion', 100)
                    lines.append(f"  {file_name}|{status}|{completion}%")

        return lines

