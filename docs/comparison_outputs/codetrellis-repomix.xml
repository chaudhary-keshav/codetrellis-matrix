import msgpack

class BinaryMetadataStore:
    def save(self, matrix: ProjectMatrix, path: Path) -> None:
        data = matrix.to_dict()
        with open(path, 'wb') as f:
            msgpack.pack(data, f)

    def load(self, path: Path) -> ProjectMatrix:
