class ResilientExtractor:
    """Error-resilient extraction wrapper."""

    def __init__(self, collector: ErrorCollector):
        self.collector = collector

    def resilient_extract(
        self,
        extractor: Callable,
        file_path: Path
    ) -> Optional[ExtractorResult]:
        try:
            return extractor(file_path)
        except Exception as e:
            self.collector.add(CodeTrellisError(
                code=CodeTrellisErrorCode.EXTRACTION_FAILED,
                message=str(e),
                file_path=str(file_path)
            ))
            return None

# 25+ standardized error codes
