        """Detect microservices from project structure"""
        services_dir = root / "services"
        if services_dir.exists():
            for service_dir in services_dir.iterdir():
                if service_dir.is_dir() and not service_dir.name.startswith("."):
                    # Try to find port from main.ts
                    main_ts = service_dir / "src" / "main.ts"
                    port = None
                    grpc_port = None

                    if main_ts.exists():
                        content = main_ts.read_text()
                        import re

                        # Find HTTP port
                        port_match = re.search(r"PORT\s*\|\|\s*(\d+)", content)
                        if port_match:
                            port = port_match.group(1)

                        # Find gRPC port
                        grpc_match = re.search(r"GRPC.*?(\d{5})", content)
                        if grpc_match:
                            grpc_port = grpc_match.group(1)

                    # Find modules
                    modules = []
                    modules_dir = service_dir / "src" / "modules"
                    if modules_dir.exists():
                        for mod_dir in modules_dir.iterdir():
                            if mod_dir.is_dir():
                                modules.append(mod_dir.name)

                    matrix.services[service_dir.name] = {
                        "path": str(service_dir),
                        "port": port,
                        "grpc_port": grpc_port,
                        "modules": modules,
                    }

