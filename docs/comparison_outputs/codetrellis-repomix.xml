class MatrixCompressor:
    """
    Compresses ProjectMatrix to minimal token format.

    Compression symbols:
        ! = required
        ? = optional
        u = unique
        [] = array
        {} = object/nested
        | = separator
        : = key-value
        , = list item
        ; = route separator

    Output Tiers:
        COMPACT: Max compression, truncation at 5 props/8 methods
        PROMPT: No truncation, full properties/methods (DEFAULT)
        FULL: Complete detail with types and docs
        JSON: Structured JSON output
    """

    # Compression dictionary for common words
    COMPRESSION_MAP = {
        "required": "!",
        "optional": "?",
        "unique": "u",
        "array": "[]",
        "object": "{}",
        "timestamps": "ts",
        "indexed": "idx",
    }

    # Truncation limits for COMPACT tier only
    COMPACT_LIMITS = {
        'properties': 5,
        'methods': 8,
        'dependencies': 5,
        'signals': 5,
        'computed': 5,
        'state': 5,
        'events': 10,
        'endpoints': 5,
