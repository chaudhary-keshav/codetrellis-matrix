    def _parse_schema(self, file_path: Path, matrix: ProjectMatrix):
        """Parse TypeScript/NestJS schema file"""
        try:
            content = file_path.read_text()
            import re

            # First pass: extract ALL enums (they're file-scoped, not class-scoped)
            enum_pattern = r'export\s+enum\s+(\w+)\s*\{([^}]+)\}'
            enum_matches = re.findall(enum_pattern, content)

            for enum_name, enum_body in enum_matches:
                values = re.findall(r"(\w+)\s*=\s*['\"]([^'\"]+)['\"]", enum_body)
                if values:
                    matrix.enums.append({
                        "name": enum_name,
                        "values": [v[1] for v in values],
                        "source": str(file_path)
                    })

            # Find ALL @Schema decorated classes with their POSITIONS
            schema_pattern = r'@Schema\([^)]*\)\s*export\s+class\s+(\w+)'

            schema_positions = []
            for match in re.finditer(schema_pattern, content):
                schema_name = match.group(1)
                start_pos = match.end()
                schema_positions.append((schema_name, start_pos))

            # For each schema, extract its body by matching braces
            for i, (schema_name, start_pos) in enumerate(schema_positions):
                # Find the opening brace after class definition
                brace_start = content.find('{', start_pos)
                if brace_start == -1:
                    continue

                # Extract class body by brace matching
                brace_count = 1
                end_pos = brace_start + 1

                while end_pos < len(content) and brace_count > 0:
                    if content[end_pos] == '{':
                        brace_count += 1
                    elif content[end_pos] == '}':
                        brace_count -= 1
                    end_pos += 1

                class_body = content[brace_start+1:end_pos-1]

                # Now find @Prop fields ONLY within this class body
                fields = []
                prop_pattern = r'@Prop\(([^)]*)\)\s*(\w+)(\?)?:\s*([^;]+);'

                for prop_match in re.finditer(prop_pattern, class_body):
                    prop_options = prop_match.group(1)
                    field_name = prop_match.group(2)
                    optional = prop_match.group(3) == '?'
                    field_type = prop_match.group(4).strip()

                    required = 'required: true' in prop_options or 'required:true' in prop_options
                    unique = 'unique: true' in prop_options or 'unique:true' in prop_options
                    indexed = 'index: true' in prop_options or 'index:true' in prop_options

                    fields.append({
                        "name": field_name,
                        "type": field_type,
                        "required": required,
                        "unique": unique,
                        "optional": optional,
                        "indexed": indexed,
                    })

                # Only add schemas that have fields (avoid empty nested schemas)
                if fields or schema_name.endswith('History') or schema_name.endswith('Document'):
                    matrix.schemas.append({
                        "name": schema_name,
                        "file": str(file_path),
                        "fields": fields,
                    })

        except Exception as e:
            print(f"[CodeTrellis] Warning: Could not parse schema {file_path}: {e}")

    def _parse_dto(self, file_path: Path, matrix: ProjectMatrix):
        """Parse DTO file"""
        try:
            content = file_path.read_text()
            import re

            # Find exported classes
            class_pattern = r'export\s+class\s+(\w+Dto)\s*\{([^}]+)\}'
            matches = re.findall(class_pattern, content, re.DOTALL)

            for class_name, class_body in matches:
                fields = []

                # Find decorated fields
                field_pattern = r'@(\w+)\([^)]*\)\s*(?:@\w+\([^)]*\)\s*)*(\w+)(?:\?)?:\s*([^;]+);'
                field_matches = re.findall(field_pattern, class_body)

                for decorator, field_name, field_type in field_matches:
                    fields.append({
                        "name": field_name,
                        "type": field_type.strip(),
                        "validators": [decorator],
                    })

                matrix.dtos.append({
                    "name": class_name,
                    "file": str(file_path),
                    "fields": fields,
                })

        except Exception as e:
            print(f"[CodeTrellis] Warning: Could not parse DTO {file_path}: {e}")

    def _parse_controller(self, file_path: Path, matrix: ProjectMatrix):
        """Parse controller file"""
        try:
            content = file_path.read_text()
            import re

            # Find controller class with decorator
            ctrl_pattern = r"@Controller\(['\"]([^'\"]*)['\"]"
            ctrl_match = re.search(ctrl_pattern, content)

            if ctrl_match:
                prefix = ctrl_match.group(1)

                # Find class name
                class_pattern = r'export\s+class\s+(\w+Controller)'
                class_match = re.search(class_pattern, content)
                class_name = class_match.group(1) if class_match else "Unknown"

                # Find route handlers
                routes = []
                route_pattern = r'@(Get|Post|Put|Delete|Patch)\([\'"]?([^\'")\s]*)[\'"]?\)'
                route_matches = re.findall(route_pattern, content)

                for method, path in route_matches:
                    routes.append({
                        "method": method.upper(),
                        "path": path or "/",
                    })

                matrix.controllers.append({
                    "name": class_name,
                    "prefix": prefix,
                    "file": str(file_path),
                    "routes": routes,
                })

        except Exception as e:
            print(f"[CodeTrellis] Warning: Could not parse controller {file_path}: {e}")

    def _parse_component(self, file_path: Path, matrix: ProjectMatrix):
        """Parse Angular component file"""
        try:
            content = file_path.read_text()
            import re

            # Find component decorator - improved to handle multi-line and nested braces
            # First, check if @Component exists
            if '@Component' not in content:
                return

            # Find class name first (more reliable)
            class_pattern = r'export\s+class\s+(\w+)'
            class_match = re.search(class_pattern, content)
            class_name = class_match.group(1) if class_match else None

            if not class_name:
                return

            # Find inputs
            inputs = []
            # @Input() decorator syntax
            input_pattern = r'@Input\(\)\s*(\w+)'
            input_matches = re.findall(input_pattern, content)
            inputs.extend(input_matches)

            # input() signal syntax (Angular 17+)
            signal_input_pattern = r'(\w+)\s*=\s*input(?:<[^>]+>)?\('
            signal_inputs = re.findall(signal_input_pattern, content)
            inputs.extend(signal_inputs)

            # input.required() syntax
            required_input_pattern = r'(\w+)\s*=\s*input\.required(?:<[^>]+>)?\('
            required_inputs = re.findall(required_input_pattern, content)
            inputs.extend(required_inputs)

            # Find outputs
            outputs = []
            # @Output() decorator syntax
            output_pattern = r'@Output\(\)\s*(\w+)'
            output_matches = re.findall(output_pattern, content)
            outputs.extend(output_matches)

            # output() signal syntax
            signal_output_pattern = r'(\w+)\s*=\s*output(?:<[^>]+>)?\('
            signal_outputs = re.findall(signal_output_pattern, content)
            outputs.extend(signal_outputs)

            matrix.components.append({
                "name": class_name,
                "file": str(file_path),
                "inputs": list(set(inputs)),  # Deduplicate
                "outputs": list(set(outputs)),  # Deduplicate
            })

        except Exception as e:
            print(f"[CodeTrellis] Warning: Could not parse component {file_path}: {e}")

