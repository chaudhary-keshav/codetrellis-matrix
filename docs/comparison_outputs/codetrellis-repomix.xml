  generics?: string[];
  documentation?: string;
}

interface TypeAliasInfo {
  name: string;
  filePath: string;
  exported: boolean;
  definition: string;
  kind: 'union' | 'intersection' | 'object' | 'function' | 'primitive' | 'generic';
  documentation?: string;
}

interface ClassInfo {
  name: string;
  filePath: string;
  exported: boolean;
  properties: PropertyInfo[];
  methods: MethodInfo[];
  extends?: string;
  implements?: string[];
  decorators?: string[];
  documentation?: string;
  // Angular-specific
  isComponent?: boolean;
  isService?: boolean;
  isDirective?: boolean;
  isPipe?: boolean;
