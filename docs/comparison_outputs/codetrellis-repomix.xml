class LazyExtractorRegistry:
    _extractors: Dict[str, Type[IExtractor]] = {}
    _instances: Dict[str, IExtractor] = {}

    @classmethod
    def get(cls, extractor_name: str) -> IExtractor:
        if extractor_name not in cls._instances:
            extractor_cls = cls._extractors.get(extractor_name)
            if extractor_cls:
                cls._instances[extractor_name] = extractor_cls()
        return cls._instances.get(extractor_name)
