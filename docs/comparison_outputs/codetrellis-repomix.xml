    entry_points = overview.get('entryPoints', [])
    if entry_points:
        print("🚀 ENTRY POINTS:")
        for entry in entry_points:
            file_path = entry.get('file', '')
            kind = entry.get('kind', 'entry')
            desc = entry.get('description', '')
            print(f"  • {file_path} ({kind}){' - ' + desc if desc else ''}")
