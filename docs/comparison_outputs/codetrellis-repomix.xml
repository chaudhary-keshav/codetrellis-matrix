"""
Universal Best Practice Definition Schema
"""

from dataclasses import dataclass, field
from typing import List, Optional, Dict, Any
from enum import Enum


class PracticeCategory(Enum):
    """Top-level practice categories"""
    LANGUAGE = "language"           # Language-specific (Python, TypeScript)
    FRAMEWORK = "framework"         # Framework-specific (Angular, NestJS)
    PATTERN = "pattern"             # Design patterns (Factory, Observer)
    PRINCIPLE = "principle"         # SOLID, DRY, KISS, etc.
    ARCHITECTURE = "architecture"   # Clean Architecture, Hexagonal
    SECURITY = "security"           # OWASP, security practices
    PERFORMANCE = "performance"     # Optimization patterns
    TESTING = "testing"             # Test patterns, TDD, BDD
    DEVOPS = "devops"              # CI/CD, Infrastructure as Code


class ProjectScale(Enum):
    """Project scale for context-aware selection"""
    PROTOTYPE = "prototype"         # Quick MVPs, PoCs
    STARTUP = "startup"             # Small teams, agile
    GROWTH = "growth"               # Scaling teams
    ENTERPRISE = "enterprise"       # Large orgs, compliance needed
    PLATFORM = "platform"           # Multi-tenant, SaaS


class CompressionLevel(Enum):
    """Output compression levels"""
    MINIMAL = "minimal"             # ~100 tokens, essential only
    STANDARD = "standard"           # ~300 tokens, balanced
    COMPREHENSIVE = "comprehensive" # ~600 tokens, full detail
    REFERENCE = "reference"         # ~1000+ tokens, documentation-level


@dataclass
class VersionConstraint:
    """Version constraints for practices"""
    min_version: Optional[str] = None           # Minimum supported version
    max_version: Optional[str] = None           # Maximum supported version (null = current)
    deprecated_in: Optional[str] = None         # Version where deprecated
    replacement: Optional[str] = None           # Replacement practice ID
    breaking_changes: Dict[str, str] = field(default_factory=dict)  # Version → breaking change description


@dataclass
class ApplicabilityRule:
    """Rules for when a practice applies"""
    project_scales: List[ProjectScale] = field(default_factory=list)   # Empty = all
    required_dependencies: List[str] = field(default_factory=list)      # Package names
    forbidden_dependencies: List[str] = field(default_factory=list)     # Conflicts
    file_patterns: List[str] = field(default_factory=list)             # Glob patterns
    code_patterns: List[str] = field(default_factory=list)             # Regex patterns in code
    metadata_conditions: Dict[str, Any] = field(default_factory=dict)  # Custom conditions


@dataclass
class PracticeContent:
    """Multi-level content for a practice"""
    minimal: str                                # Compressed format
    standard: str                               # Balanced format
    comprehensive: str                          # Detailed format
    reference: str                              # Full documentation
    examples: List[Dict[str, str]] = field(default_factory=list)  # Code examples


@dataclass
class BestPractice:
    """Universal Best Practice Definition"""
    id: str                                     # Unique identifier (e.g., "python.naming.snake_case")
    name: str                                   # Human-readable name
    category: PracticeCategory
    subcategory: Optional[str] = None           # e.g., "naming", "typing", "error_handling"

    # Metadata
    description: str = ""
    rationale: str = ""                         # Why this practice exists
    tags: List[str] = field(default_factory=list)

    # Version awareness
    language: Optional[str] = None              # e.g., "python", "typescript"
    framework: Optional[str] = None             # e.g., "angular", "fastapi"
    version: VersionConstraint = field(default_factory=VersionConstraint)

    # Content at different compression levels
    content: PracticeContent = None

    # Applicability
    applicability: ApplicabilityRule = field(default_factory=ApplicabilityRule)

    # Relations
    related_practices: List[str] = field(default_factory=list)  # Practice IDs
    conflicts_with: List[str] = field(default_factory=list)     # Practice IDs

    # Quality metrics
    priority: int = 5                           # 1-10, higher = more important
    enforcement_level: str = "recommended"      # "required", "recommended", "optional"

    # Source/Attribution
    sources: List[str] = field(default_factory=list)  # URLs, PEPs, RFCs, etc.
    author: str = ""
    last_updated: str = ""
