  pnl?: number;
  pnl_pct?: number;
  confidence: number;
  reason?: string;
  entry_price?: number;
  charges?: number;
}
```

**Backend Trade Format (Trade Executor):**

```typescript
interface Trade {
  executedAt: string; // Different field name
