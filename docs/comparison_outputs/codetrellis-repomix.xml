  });

  // === COMPUTED SIGNALS ===
  // Store-derived computed
  readonly positions = computed(() => this.portfolioStore.positions());
  readonly totalPnL = computed(() => this.portfolioStore.totalPnL());
  readonly totalValue = computed(() => this.portfolioStore.totalValue());
  readonly openOrders = computed(() => this.ordersStore.openOrders());
