    def _compress_python_functions(self, matrix) -> List[str]:
        """Compress important Python functions"""
        lines = []

        if hasattr(matrix, 'python_functions') and matrix.python_functions:
            # Group by file for organization
            funcs_by_file = {}
            for func in matrix.python_functions:
                file_path = func.get('file', 'unknown')
                # Get just the filename
                filename = file_path.split('/')[-1] if '/' in file_path else file_path
                if filename not in funcs_by_file:
                    funcs_by_file[filename] = []
                funcs_by_file[filename].append(func)

            # Output functions grouped by file (limit to avoid massive output)
            file_count = 0
            for filename, funcs in funcs_by_file.items():
                if file_count >= 10:  # Limit to 10 files
                    remaining = len(funcs_by_file) - file_count
                    lines.append(f"  # ... and {remaining} more files")
                    break

                # Only show files with interesting functions
                interesting_funcs = [f for f in funcs if f.get('is_async') or f.get('decorators')]
                if interesting_funcs:
                    lines.append(f"  # {filename}")
                    for func in interesting_funcs[:5]:  # Limit to 5 funcs per file
                        async_str = "async " if func.get('is_async') else ""
                        decorators = func.get('decorators', [])
                        dec_str = f"|@{','.join(str(d) for d in decorators)}" if decorators else ""
                        params = func.get('params', [])
                        # Convert params to strings (handle both string params and ParameterInfo objects)
                        param_strs = []
                        for p in params[:4]:
                            if isinstance(p, str):
                                param_strs.append(p)
                            elif hasattr(p, 'name'):
                                param_strs.append(p.name)
                            else:
                                param_strs.append(str(p))
                        params_str = ','.join(param_strs)
                        ret = func.get('return_type', '')
                        ret_str = f"->{ret}" if ret else ""
                        lines.append(f"    {async_str}{func['name']}({params_str}){ret_str}{dec_str}")
                    file_count += 1

        return lines

    def _compress_logic(self, matrix) -> List[str]:
        """
        v4.1: Compress implementation logic snippets.
        Addresses: "AI can't see specific code logic" limitation.

        Output format:
        # file.ts (N functions, M complex)
          ClassName.methodName|signature|flow:[if,for,try]|api:[GET,POST]|transforms:[map,filter]|key ops
        """
        lines = []

        if not hasattr(matrix, 'logic_snippets') or not matrix.logic_snippets:
            return lines

        # Group snippets by file
        snippets_by_file = {}
        for snippet in matrix.logic_snippets:
            file_path = snippet.get('file', 'unknown')
            # Get just the filename
            filename = file_path.split('/')[-1] if '/' in file_path else file_path
            if filename not in snippets_by_file:
                snippets_by_file[filename] = []
            snippets_by_file[filename].append(snippet)

        # Limit files to avoid massive output
        for i, (filename, snippets) in enumerate(snippets_by_file.items()):
            if self.tier == OutputTier.COMPACT and i >= 15:  # Limit in COMPACT
                remaining = len(snippets_by_file) - i
                lines.append(f"# ... and {remaining} more files with logic")
                break

            if self.tier == OutputTier.PROMPT and i >= 30:  # More in PROMPT
                remaining = len(snippets_by_file) - i
                lines.append(f"# ... and {remaining} more files")
                break

            # Count complexity
            complex_count = sum(1 for s in snippets if s.get('complexity') == 'complex')
            total = len(snippets)

            lines.append(f"# {filename} ({total} functions, {complex_count} complex)")

            # Sort by complexity (complex first - they're more important)
            snippets.sort(key=lambda x: {'complex': 0, 'moderate': 1, 'simple': 2}.get(x.get('complexity', 'simple'), 2))

            # Limit snippets per file
            max_per_file = 5 if self.tier == OutputTier.COMPACT else 10
            for j, snippet in enumerate(snippets):
                if j >= max_per_file:
                    remaining = len(snippets) - j
                    lines.append(f"  # ... and {remaining} more functions")
                    break

                # Build compressed line
                parts = [f"  {snippet['name']}"]

                # Add signature (abbreviated)
                sig = snippet.get('signature', '')
                if sig and len(sig) > 50:
                    sig = sig[:47] + "..."
                if sig:
                    parts.append(sig)

                # Add logic summary
                summary = snippet.get('logic_summary', '')
                if summary:
                    parts.append(summary)

                # Add complexity marker for non-simple functions
                complexity = snippet.get('complexity', 'simple')
                if complexity != 'simple':
                    parts.append(f"[{complexity}]")

                lines.append('|'.join(parts))

            lines.append("")  # Blank line between files

        # Add stats summary
        if hasattr(matrix, 'logic_stats') and matrix.logic_stats:
            stats = matrix.logic_stats
            lines.append(f"# LOGIC_STATS: {stats.get('total_snippets', 0)} snippets | "
                        f"simple:{stats.get('simple', 0)} moderate:{stats.get('moderate', 0)} complex:{stats.get('complex', 0)}")

        return lines

    def _compress_python_fields(self, fields: List[Dict]) -> str:
        """Compress field list to compact format"""
        if not fields:
            return ""

        field_strs = []
        for field in fields[:10]:  # Limit to 10 fields
            name = field.get('name', '')
            type_hint = field.get('type', 'Any')
            required = field.get('required', True)
            req_marker = "!" if required else "?"
            field_strs.append(f"{name}{req_marker}:{type_hint}")

        result = ','.join(field_strs)
        if len(fields) > 10:
            result += f",+{len(fields) - 10}more"

        return result

    def _group_by_service(self, items: List[Dict]) -> Dict[str, List[Dict]]:
        """Group items by their service based on file path"""
        groups = {}

        for item in items:
            file_path = item.get('file', '')

            # Extract service name from path
            if 'services/' in file_path:
                parts = file_path.split('services/')[1].split('/')
                service = parts[0] if parts else 'unknown'
            elif 'ai/' in file_path:
                parts = file_path.split('ai/')[1].split('/')
                service = f"ai/{parts[0]}" if parts else 'ai'
            else:
                service = 'root'

            if service not in groups:
                groups[service] = []
            groups[service].append(item)

        return groups

    def _get_best_practices(self, stack: List[str]) -> List[str]:
        """Get best practices based on detected stack"""
        practices = []

        for item in stack:
            if item.startswith('nestjs'):
                version = item.split(':')[1] if ':' in item else '10'
                major = version.split('.')[0]
                practices.append(f"nestjs:{major}|use:DI,DTOs,Guards,Logger|avoid:any,console.log")

            elif item.startswith('angular'):
                version = item.split(':')[1] if ':' in item else '20'
                major = version.split('.')[0]
                if int(major) >= 17:
                    practices.append(f"angular:{major}|use:Signals,StandaloneComponents,@if/@for,OnPush|avoid:*ngIf,subscribe-without-cleanup")
                else:
                    practices.append(f"angular:{major}|use:OnPush,AsyncPipe,TrackBy|avoid:subscribe-without-cleanup")

        return practices

    def to_json(self, matrix) -> str:
        """Export matrix as JSON (for tooling)"""
        return json.dumps(matrix.to_dict(), indent=2, default=str)

    def get_stats(self, matrix, compressed: str) -> CompressionStats:
        """Get compression statistics"""
        return CompressionStats(
            original_files=matrix.total_files,
            total_tokens=len(compressed) // 4,  # Rough estimate
            schemas=len(matrix.schemas),
            dtos=len(matrix.dtos),
            controllers=len(matrix.controllers),
            components=len(matrix.components),
            services=len(matrix.services),
        )


def compress_matrix(matrix, max_tokens: int = 2000, tier: OutputTier = OutputTier.PROMPT) -> str:
    """
    Convenience function to compress a matrix.

    Args:
        matrix: ProjectMatrix to compress
        max_tokens: Token limit (only applies to COMPACT tier)
        tier: OutputTier enum - COMPACT, PROMPT (default), FULL, or JSON

    Returns:
        Compressed string
    """
    compressor = MatrixCompressor(max_tokens=max_tokens, tier=tier)
    return compressor.compress(matrix)


