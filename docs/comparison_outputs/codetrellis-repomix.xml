    def _compress_data_flows(self, business_domain: dict) -> List[str]:
        """
        Compress data flow patterns for understanding system architecture.

        Format:
            pattern:Real-time Streaming
            flow:Backend/WebSocket→Frontend State|events:price_update,signal_update
            flow:Frontend→Backend API|events:POST /trades,GET /positions

        Args:
            business_domain: BusinessDomainContext dict

        Returns:
            List of compressed lines
        """
        lines = []

        # Primary data pattern
        primary_pattern = business_domain.get('primaryDataPattern', 'Request-Response')
        lines.append(f"primary-pattern:{primary_pattern}")

        # Individual flows
        data_flows = business_domain.get('dataFlows', [])
        for flow in data_flows[:5]:  # Limit to 5 flows
            source = flow.get('source', '')
            dest = flow.get('destination', '')
            pattern = flow.get('pattern', '')
            events = flow.get('events', [])[:5]

            flow_str = f"{source}→{dest}"
            if pattern:
                flow_str += f"|pattern:{pattern}"
            if events:
                flow_str += f"|events:{','.join(events)}"

            lines.append(f"flow:{flow_str}")

        # Description for each flow (FULL mode only)
        if self.tier == OutputTier.FULL:
            for flow in data_flows[:5]:
                desc = flow.get('description', '')
                if desc:
                    lines.append(f"# {flow.get('name', '')}: {desc[:100]}")

        return lines

    def _compress_decisions(self, business_domain: dict) -> List[str]:
        """
        Compress architectural decisions for understanding design rationale.

        Format:
            decision:State Management|NgRx Signal Store|rationale:Fine-grained reactivity
            decision:Real-time|WebSocket|evidence:51 WS events detected

        Args:
            business_domain: BusinessDomainContext dict

        Returns:
            List of compressed lines
        """
        lines = []

        decisions = business_domain.get('decisions', [])

        for decision in decisions[:6]:  # Limit to 6 key decisions
            title = decision.get('title', '')
            choice = decision.get('decision', '')
            rationale = decision.get('rationale', '')[:60] if decision.get('rationale') else ''
            evidence = decision.get('evidence', [])

            line = f"decision:{title}|{choice}"
            if rationale:
                line += f"|rationale:{rationale}"

            lines.append(line)

            # In PROMPT/FULL mode, add evidence
            if self.tier != OutputTier.COMPACT and evidence:
                evidence_str = ','.join(str(e)[:30] for e in evidence[:3])
                lines.append(f"  evidence:[{evidence_str}]")

            # In FULL mode, add alternatives
            if self.tier == OutputTier.FULL:
                alternatives = decision.get('alternatives', [])
                if alternatives:
                    lines.append(f"  alternatives:{','.join(alternatives[:4])}")

        return lines

