    def _deduplicate_interfaces(self, interfaces: List[Dict]) -> List[Dict]:
        """
        Remove duplicate interfaces based on name and file_path.

        Report 2 Issue 3.5: Position interface was appearing twice in matrix output.
        This ensures each interface is only included once.

        Args:
            interfaces: List of interface dictionaries

        Returns:
            Deduplicated list of interfaces
        """
        seen = {}
        for iface in interfaces:
            name = iface.get('name', '')
            file_path = iface.get('file_path', iface.get('filePath', ''))
            key = (name, file_path)
            if key not in seen:
                seen[key] = iface
        return list(seen.values())

    def _deduplicate_by_name(self, items: List[Dict], name_key: str = 'name') -> List[Dict]:
        """
        Generic deduplication by a name key.

        Args:
            items: List of dictionaries to deduplicate
            name_key: Key to use for deduplication

        Returns:
            Deduplicated list
        """
        seen = {}
        for item in items:
            name = item.get(name_key, '')
            if name and name not in seen:
                seen[name] = item
        return list(seen.values())

